# ===============================================================
# lateralus.dev — Environment Configuration
# Copy to .env and fill in secrets before deploying
# ===============================================================

# Bind address
BIND_HOST=0.0.0.0
BIND_PORT=8443

# TLS certificates (use Let's Encrypt / certbot)
TLS_CERT=/etc/letsencrypt/live/lateralus.dev/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/lateralus.dev/privkey.pem

# Token-based access to /me and /resume
LINK_SECRET=CHANGE_ME_64_char_random_hex_string
ADMIN_PASS=CHANGE_ME_strong_admin_password

# Path to the public/ directory containing static HTML/CSS/JS
STATIC_ROOT=/srv/lateralus.dev/public

# Logging
LOG_LEVEL=info
