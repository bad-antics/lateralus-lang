{
  "name": "lateralus-lang",
  "displayName": "Lateralus Language",
  "description": "Full language support for Lateralus (.ltl) — syntax highlighting, LSP diagnostics, completions, hover, go-to-definition, find references, formatting, code actions, signature help, document symbols, rename, folding, bracket matching, and snippets. Also supports Lateralus Assembly (.ltasm), Markup (.ltlm/.ltlml), Config (.ltlcfg), Notebooks (.ltlnb), Bytecode (.ltbc), and Compiled (.ltlc) files.",
  "version": "2.5.0",
  "publisher": "lateralus",
  "license": "MIT",
  "main": "./extension.js",
  "icon": "icons/lateralus-logo.svg",
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [
    "onLanguage:lateralus",
    "onLanguage:lateralus-asm",
    "onLanguage:lateralus-markup",
    "onLanguage:lateralus-cfg",
    "onLanguage:lateralus-notebook"
  ],
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "lateralus",
    "ltl",
    "ltasm",
    "ltlcfg",
    "ltlnb",
    "ltbc",
    "ltlc",
    "lateralus-lang",
    "lateralus assembly",
    "lateralus config",
    "lateralus notebook",
    "lateralus bytecode",
    "pipeline",
    "language server",
    "lsp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bad-antics/lateralus-lang"
  },
  "bugs": {
    "url": "https://github.com/bad-antics/lateralus-lang/issues"
  },
  "homepage": "https://github.com/bad-antics/lateralus-lang#readme",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "contributes": {
    "languages": [
      {
        "id": "lateralus",
        "aliases": [
          "Lateralus",
          "lateralus",
          "ltl"
        ],
        "extensions": [
          ".ltl"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/lateralus-light.svg",
          "dark": "./icons/lateralus-dark.svg"
        }
      },
      {
        "id": "lateralus-asm",
        "aliases": [
          "Lateralus Assembly",
          "ltasm"
        ],
        "extensions": [
          ".ltasm"
        ],
        "configuration": "./language-configuration-asm.json",
        "icon": {
          "light": "./icons/lateralus-asm-light.svg",
          "dark": "./icons/lateralus-asm-dark.svg"
        }
      },
      {
        "id": "lateralus-markup",
        "aliases": [
          "Lateralus Markup",
          "ltlm",
          "ltlml"
        ],
        "extensions": [
          ".ltlm",
          ".ltlml"
        ],
        "configuration": "./language-configuration-markup.json",
        "icon": {
          "light": "./icons/lateralus-markup-light.svg",
          "dark": "./icons/lateralus-markup-dark.svg"
        }
      },
      {
        "id": "lateralus-cfg",
        "aliases": [
          "Lateralus Config",
          "ltlcfg"
        ],
        "extensions": [
          ".ltlcfg"
        ],
        "configuration": "./language-configuration-cfg.json",
        "icon": {
          "light": "./icons/lateralus-cfg-light.svg",
          "dark": "./icons/lateralus-cfg-dark.svg"
        }
      },
      {
        "id": "lateralus-notebook",
        "aliases": [
          "Lateralus Notebook",
          "ltlnb"
        ],
        "extensions": [
          ".ltlnb"
        ],
        "configuration": "./language-configuration-notebook.json",
        "icon": {
          "light": "./icons/lateralus-notebook-light.svg",
          "dark": "./icons/lateralus-notebook-dark.svg"
        }
      },
      {
        "id": "lateralus-bytecode",
        "aliases": [
          "Lateralus Bytecode",
          "ltbc"
        ],
        "extensions": [
          ".ltbc"
        ],
        "icon": {
          "light": "./icons/lateralus-bytecode-light.svg",
          "dark": "./icons/lateralus-bytecode-dark.svg"
        }
      },
      {
        "id": "lateralus-compiled",
        "aliases": [
          "Lateralus Compiled",
          "ltlc"
        ],
        "extensions": [
          ".ltlc"
        ],
        "icon": {
          "light": "./icons/lateralus-compiled-light.svg",
          "dark": "./icons/lateralus-compiled-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "lateralus",
        "scopeName": "source.ltl",
        "path": "./syntaxes/lateralus.tmLanguage.json"
      },
      {
        "language": "lateralus-asm",
        "scopeName": "source.ltasm",
        "path": "./syntaxes/lateralus-asm.tmLanguage.json"
      },
      {
        "language": "lateralus-markup",
        "scopeName": "source.ltlm",
        "path": "./syntaxes/lateralus-markup.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.lateralus": "lateralus",
          "meta.embedded.block.lateralus-asm": "lateralus-asm"
        }
      },
      {
        "language": "lateralus-cfg",
        "scopeName": "source.ltlcfg",
        "path": "./syntaxes/lateralus-cfg.tmLanguage.json"
      },
      {
        "language": "lateralus-notebook",
        "scopeName": "source.ltlnb",
        "path": "./syntaxes/lateralus-notebook.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "lateralus",
        "path": "./snippets/lateralus.json"
      },
      {
        "language": "lateralus-asm",
        "path": "./snippets/lateralus-asm.json"
      },
      {
        "language": "lateralus-markup",
        "path": "./snippets/lateralus-markup.json"
      },
      {
        "language": "lateralus-cfg",
        "path": "./snippets/lateralus-cfg.json"
      },
      {
        "language": "lateralus-notebook",
        "path": "./snippets/lateralus-notebook.json"
      }
    ],
    "commands": [
      {
        "command": "lateralus.restartServer",
        "title": "Restart Language Server",
        "category": "Lateralus"
      },
      {
        "command": "lateralus.showOutput",
        "title": "Show Output Channel",
        "category": "Lateralus"
      },
      {
        "command": "lateralus.formatDocument",
        "title": "Format Document",
        "category": "Lateralus"
      },
      {
        "command": "lateralus.organizeImports",
        "title": "Organize Imports",
        "category": "Lateralus"
      }
    ],
    "keybindings": [
      {
        "command": "lateralus.organizeImports",
        "key": "shift+alt+o",
        "when": "editorLangId == lateralus"
      }
    ],
    "configuration": {
      "title": "Lateralus",
      "properties": {
        "lateralus.enableLSP": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Lateralus Language Server for diagnostics, completions, hover, and all LSP features."
        },
        "lateralus.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to Python interpreter for the LSP server. Leave empty to auto-detect."
        },
        "lateralus.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format Lateralus files on save."
        },
        "lateralus.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace communication between VS Code and the Lateralus language server."
        }
      }
    }
  }
}
