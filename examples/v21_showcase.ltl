fn main() {
    println("═══ Lateralus v2.1 Advanced Features ═══\n")

    // Sensor readings via interfaces
    println("Sensor readings:")
    let sensors = [
        Sensor { name: "Temperature", value: 23.5, unit: "C" },
        Sensor { name: "Humidity",    value: 67.2, unit: "%" },
        Sensor { name: "Pressure",    value: 1013.25, unit: "hPa" },
    ]
    println("  " + format_readings(sensors))
    let total = sensors |> map(fn(s) { s.reading() }) |> sum()
    println("  Sum of readings: " + str(round(total, 2)))

    pipeline_demo()
    meta_demo()
    result_demo()
    perf_demo()
    iter_demo()
    crypto_demo()
    matrix_demo()
    fsm_demo()

    println("\n═══ All demos complete ═══")
}

main()
