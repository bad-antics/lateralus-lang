// Test exhaustive + oracle law modes (v3.2 novel features)

// ── Exhaustive: all-bool params → PROVED over 2^n cases ──

@law
fn and_commutative(p: bool, q: bool) -> bool {
    return (p and q) == (q and p)
}

@law
fn de_morgan_1(p: bool, q: bool) -> bool {
    return (not (p and q)) == ((not p) or (not q))
}

@law
fn de_morgan_2(p: bool, q: bool) -> bool {
    return (not (p or q)) == ((not p) and (not q))
}

// ── Exhaustive with bound: int params over [-bound, bound] ──

@law(bound = 5)
fn add_commutative_proved(a: int, b: int) -> bool {
    return a + b == b + a
}

@law(bound = 4)
fn mul_distributes_over_add_proved(a: int, b: int, c: int) -> bool {
    return a * (b + c) == a * b + a * c
}

// ── Oracle (differential) laws ──

fn slow_fact(n: int) -> int {
    let mut result = 1
    let mut i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}

fn fast_fact(n: int) -> int {
    if n <= 1 { return 1 }
    return n * fast_fact(n - 1)
}

@law(oracle = slow_fact)
fn fast_fact_matches_slow(n: int) -> int {
    assume(n >= 0)
    assume(n <= 8)
    return fast_fact(n)
}
