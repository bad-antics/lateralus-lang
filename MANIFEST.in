# ── LATERALUS Language — Source Distribution Manifest ──────────────────
# This file controls what goes into the sdist (.tar.gz) archive.

# Package metadata
include pyproject.toml
include README.md
include CHANGELOG.md
include RELEASE_NOTES.md
include CONTRIBUTING.md
include ROADMAP.md
include Makefile
include LICENSE*

# CLI entry point
include bin/ltlc

# Standard library (shipped with the package)
recursive-include stdlib *.ltl

# Example programs
recursive-include examples *.ltl *.ltasm

# Documentation sources
recursive-include docs *.ltlml *.ebnf
recursive-include docs/html *.html *.css *.js
recursive-include docs/spec *.md *.txt

# Grammar / spec
include docs/grammar.ebnf

# VS Code extension (so testers can install it)
recursive-include vscode-lateralus *.json *.js *.md
recursive-include vscode-lateralus/syntaxes *.json *.tmLanguage *.tmLanguage.json
recursive-include vscode-lateralus/snippets *.json
recursive-include vscode-lateralus/icons *.png *.svg *.ico

# Bootstrap sources
recursive-include bootstrap *.ltl

# Exclude dev/build artifacts
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude .git*
global-exclude .DS_Store
