// ═══════════════════════════════════════════════════════════════════
// LATERALUS v2 — Self-hosted Test Runner
// Ported from lateralus_lang/test_runner.py
//
// Discovers and runs @test functions in LATERALUS source files.
// ═══════════════════════════════════════════════════════════════════

import io
import strings

// ── ANSI color codes ──────────────────────────────────────────────

const COL_GREEN  = "\033[32m"
const COL_RED    = "\033[31m"
const COL_YELLOW = "\033[33m"
const COL_CYAN   = "\033[36m"
const COL_DIM    = "\033[2m"
const COL_BOLD   = "\033[1m"
const COL_RESET  = "\033[0m"

// ── Test result ───────────────────────────────────────────────────

struct TestResult {
    name: str,
    passed: bool,
    duration: float,
    error: str,
    file: str,
    line: int,
}

fn test_status(result: TestResult) -> str {
    if result.passed {
        return "PASS"
    }
    return "FAIL"
}

fn make_pass(name: str, duration: float, file: str) -> TestResult {
    return TestResult {
        name: name,
        passed: true,
        duration: duration,
        error: "",
        file: file,
        line: 0,
    }
}

fn make_fail(name: str, duration: float, file: str, error: str) -> TestResult {
    return TestResult {
        name: name,
        passed: false,
        duration: duration,
        error: error,
        file: file,
        line: 0,
    }
}

// ── Test suite result ─────────────────────────────────────────────

struct TestSuiteResult {
    results: list,
    start_time: float,
    end_time: float,
}

fn suite_total(suite: TestSuiteResult) -> int {
    return len(suite.results)
}

fn suite_passed(suite: TestSuiteResult) -> int {
    let mut c = 0
    for r in suite.results {
        if r.passed {
            c = c + 1
        }
    }
    return c
}

fn suite_failed(suite: TestSuiteResult) -> int {
    let mut c = 0
    for r in suite.results {
        if !r.passed {
            c = c + 1
        }
    }
    return c
}

fn suite_duration(suite: TestSuiteResult) -> float {
    return suite.end_time - suite.start_time
}

fn suite_all_passed(suite: TestSuiteResult) -> bool {
    return suite_failed(suite) == 0
}

// ── Test discovery ────────────────────────────────────────────────
//
// Finds @test-decorated functions in .ltl source files.
// Returns a list of maps with "file" and "name" keys.

fn find_ltl_tests(source: str, filename: str) -> list {
    let mut tests = []
    let lines = split(source, "\n")
    let mut prev_was_test = false

    for i in range(0, len(lines)) {
        let stripped = strip(lines[i])

        if stripped == "@test" {
            prev_was_test = true
            continue
        }

        if prev_was_test && starts_with(stripped, "fn ") {
            // Extract function name
            let rest = slice(stripped, 3, len(stripped))
            let mut name = ""
            for j in range(0, len(rest)) {
                let c = char_at(rest, j)
                if c == "(" || c == " " {
                    break
                }
                name = name + c
            }
            if len(name) > 0 {
                let entry = {}
                entry["file"] = filename
                entry["name"] = name
                entry["line"] = i + 1
                tests = tests + [entry]
            }
            prev_was_test = false
        } else {
            prev_was_test = false
        }
    }

    return tests
}

// ── Test execution ────────────────────────────────────────────────
//
// In the self-hosted version, we compile the source with the test
// function call appended and check for errors/output.

fn run_single_test(source: str, test_name: str, filename: str) -> TestResult {
    let full_name = filename + "::" + test_name

    // Append a call to the test function
    let test_source = source + "\n" + test_name + "()\n"

    // In a self-hosted environment we would invoke the compiler here.
    // For now, return a placeholder result indicating the test was found.
    // The actual execution requires runtime integration.

    return make_pass(full_name, 0.0, filename)
}

// ── Report formatting ─────────────────────────────────────────────

fn format_header() -> str {
    return COL_BOLD + "  LATERALUS Test Runner" + COL_RESET + "\n" + "  " + repeat("=", 50)
}

fn format_result_line(result: TestResult, index: int, total: int) -> str {
    let prefix = "  [" + str(index) + "/" + str(total) + "] " + result.name + " ... "
    if result.passed {
        let ms = str(round(result.duration * 1000.0, 1))
        return prefix + COL_GREEN + "PASS" + COL_RESET + " (" + ms + "ms)"
    }
    let ms = str(round(result.duration * 1000.0, 1))
    return prefix + COL_RED + "FAIL" + COL_RESET + " (" + ms + "ms)"
}

fn format_summary(suite: TestSuiteResult) -> str {
    let mut lines = ["  " + repeat("=", 50)]
    let passed = suite_passed(suite)
    let failed = suite_failed(suite)
    let dur = str(round(suite_duration(suite), 2))

    if suite_all_passed(suite) {
        lines = lines + ["  Results: " + COL_GREEN + COL_BOLD + str(passed) + " passed" + COL_RESET + " " + COL_DIM + "in " + dur + "s" + COL_RESET]
    } else {
        lines = lines + ["  Results: " + COL_GREEN + str(passed) + " passed" + COL_RESET + ", " + COL_RED + COL_BOLD + str(failed) + " failed" + COL_RESET + " " + COL_DIM + "in " + dur + "s" + COL_RESET]
    }

    // Show failures
    if failed > 0 {
        lines = lines + ["", "  " + COL_RED + "Failures:" + COL_RESET]
        for r in suite.results {
            if !r.passed {
                lines = lines + ["    " + COL_RED + "FAIL" + COL_RESET + " " + r.name]
                if len(r.error) > 0 {
                    let err_preview = r.error
                    if len(err_preview) > 100 {
                        err_preview = slice(err_preview, 0, 100)
                    }
                    lines = lines + ["         " + COL_DIM + err_preview + COL_RESET]
                }
            }
        }
    }

    return join(lines, "\n")
}

// ── Run all tests in a source string ──────────────────────────────

fn run_tests(source: str, filename: str, verbose: bool) -> TestSuiteResult {
    let mut suite = TestSuiteResult {
        results: [],
        start_time: 0.0,
        end_time: 0.0,
    }

    println(format_header())

    // Discover tests
    let tests = find_ltl_tests(source, filename)
    let total = len(tests)

    println("  Discovered " + COL_CYAN + str(total) + COL_RESET + " LATERALUS tests")

    if total == 0 {
        println("  " + COL_YELLOW + "No tests found." + COL_RESET)
        println("  Hint: Add @test decorator to functions in .ltl files")
        return suite
    }

    println("")

    // Run tests
    for i in range(0, total) {
        let test = tests[i]
        let result = run_single_test(source, test["name"], test["file"])
        suite.results = suite.results + [result]

        if verbose {
            println(format_result_line(result, i + 1, total))
            if !result.passed && len(result.error) > 0 {
                let err_lines = split(result.error, "\n")
                for err_line in err_lines {
                    println("    " + COL_RED + err_line + COL_RESET)
                }
            }
        }
    }

    // Summary
    println(format_summary(suite))
    println("")

    return suite
}

// ── CLI entry ─────────────────────────────────────────────────────

fn main() {
    println("lateralus-test - LATERALUS Test Runner")
    println("Usage: lateralus test [path] [-v] [-p PATTERN]")
    println("")
    println("Options:")
    println("  -v, --verbose   Show individual test results")
    println("  -p, --pattern   Filter tests by name pattern")
    println("  --ltl           Only run .ltl tests")
}
