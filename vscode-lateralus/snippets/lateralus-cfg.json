{
  "Section": {
    "prefix": "section",
    "body": [
      "[${1:section_name}]",
      "${2:key}: ${3:str} = ${4:\"value\"}",
      "$0"
    ],
    "description": "Create a new config section"
  },
  "Typed Field (String)": {
    "prefix": "str-field",
    "body": "${1:name}: str = \"${2:value}\"",
    "description": "String config field"
  },
  "Typed Field (Int)": {
    "prefix": "int-field",
    "body": "${1:name}: int = ${2:0}",
    "description": "Integer config field"
  },
  "Typed Field (Float)": {
    "prefix": "float-field",
    "body": "${1:name}: float = ${2:0.0}",
    "description": "Float config field"
  },
  "Typed Field (Bool)": {
    "prefix": "bool-field",
    "body": "${1:name}: bool = ${2|true,false|}",
    "description": "Boolean config field"
  },
  "Typed Field (List)": {
    "prefix": "list-field",
    "body": "${1:name}: list[${2:str}] = [${3:\"item1\", \"item2\"}]",
    "description": "List config field"
  },
  "Include Directive": {
    "prefix": "include",
    "body": "!include ${1:other.ltlcfg}",
    "description": "Include another config file"
  },
  "Environment Variable": {
    "prefix": "env",
    "body": "\\${${1:ENV_VAR}}",
    "description": "Environment variable substitution"
  },
  "Server Section": {
    "prefix": "server-section",
    "body": [
      "[server]",
      "host: str = \"${1:localhost}\"",
      "port: int = ${2:8080}",
      "debug: bool = ${3:false}",
      "workers: int = ${4:4}",
      "$0"
    ],
    "description": "Common server configuration section"
  },
  "Database Section": {
    "prefix": "db-section",
    "body": [
      "[database]",
      "url: str = \"${1:sqlite:///db.ltldb}\"",
      "pool_size: int = ${2:5}",
      "timeout: float = ${3:30.0}",
      "$0"
    ],
    "description": "Common database configuration section"
  }
}
