{h2 Chapter 9: Configuration Management}

{h3 Recipe 9.1 — Typed App Config with Validation}

{code lang="lateralus"
import "ltlcfg"

-- Define schema
let schema = ConfigSchema()
schema.section("server")
    .field("host",    "str",   default: "0.0.0.0")
    .field("port",    "int",   default: 8080, min: 1, max: 65535)
    .field("debug",   "bool",  default: false)
    .field("workers", "int",   default: 4,    min: 1)

schema.section("database")
    .field("url",       "str",   required: true)
    .field("pool_size", "int",   default: 5)

-- Load and validate
let config = ltlcfg.load_config("config/app.ltlcfg", schema)

-- Access values
println("Listening on " + config.server.host + ":" + str(config.server.port))
println("DB: " + config.database.url)
}

