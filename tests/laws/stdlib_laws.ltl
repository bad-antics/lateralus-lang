// ===================================================================
// LATERALUS — Canonical stdlib laws
// Executable specifications for built-in operations. Run by pytest.
// ===================================================================

// ---- Arithmetic laws (hold for all int inputs) --------------------

@law
fn add_is_commutative(a: int, b: int) -> bool {
    return a + b == b + a
}

@law
fn add_is_associative(a: int, b: int, c: int) -> bool {
    return (a + b) + c == a + (b + c)
}

@law
fn mul_distributes_over_add(a: int, b: int, c: int) -> bool {
    return a * (b + c) == a * b + a * c
}

@law
fn sub_inverse_of_add(a: int, b: int) -> bool {
    return (a + b) - b == a
}

@law
fn zero_is_additive_identity(a: int) -> bool {
    return a + 0 == a and 0 + a == a
}

@law
fn one_is_multiplicative_identity(a: int) -> bool {
    return a * 1 == a and 1 * a == a
}

@law
fn negation_is_involutive(a: int) -> bool {
    return -(-a) == a
}

@law
fn abs_is_non_negative(a: int) -> bool {
    let r = a
    let absval = r < 0 ? -r : r
    return absval >= 0
}

// ---- Integer division / modulo -----------------------------------

// ---- Integer division / modulo -----------------------------------

@law
fn idiv_mod_reconstructs(a: int, b: int) -> bool {
    // Lateralus `/` is float division (matches Python). For integer
    // arithmetic use `idiv(a, b)` — floor division, Python-compatible.
    // This law captures the fundamental Euclidean identity:
    //     idiv(a, b) * b + imod(a, b) == a
    assume(b != 0)
    return idiv(a, b) * b + imod(a, b) == a
}

@law
fn divmod_matches_idiv_imod(a: int, b: int) -> bool {
    assume(b != 0)
    let qr = divmod(a, b)
    return qr[0] == idiv(a, b) and qr[1] == imod(a, b)
}

@law
fn mod_bounded_by_divisor(a: int, b: int) -> bool {
    assume(b > 0)
    assume(a >= 0)
    let r = a % b
    return r >= 0 and r < b
}

@law
fn gcd_divides_both(a: int, b: int) -> bool {
    assume(a > 0)
    assume(b > 0)
    let g = gcd(a, b)
    return a % g == 0 and b % g == 0
}

@law
fn gcd_is_commutative(a: int, b: int) -> bool {
    assume(a > 0)
    assume(b > 0)
    return gcd(a, b) == gcd(b, a)
}

@law
fn sign_is_consistent(a: int) -> bool {
    let s = sign(a)
    if a > 0 { return s == 1 }
    if a < 0 { return s == -1 }
    return s == 0
}

@law
fn clamp_is_bounded(v: int, lo: int, hi: int) -> bool {
    assume(lo <= hi)
    let c = clamp(v, lo, hi)
    return c >= lo and c <= hi
}

@law
fn clamp_identity_within_range(v: int, lo: int, hi: int) -> bool {
    assume(lo <= v)
    assume(v <= hi)
    return clamp(v, lo, hi) == v
}

@law
fn even_odd_partition(n: int) -> bool {
    return is_even(n) != is_odd(n)
}

// ---- Boolean algebra ---------------------------------------------

@law
fn and_is_commutative(p: bool, q: bool) -> bool {
    return (p and q) == (q and p)
}

@law
fn or_is_commutative(p: bool, q: bool) -> bool {
    return (p or q) == (q or p)
}

@law
fn de_morgan_and(p: bool, q: bool) -> bool {
    let lhs = not (p and q)
    let rhs = (not p) or (not q)
    return lhs == rhs
}

@law
fn de_morgan_or(p: bool, q: bool) -> bool {
    let lhs = not (p or q)
    let rhs = (not p) and (not q)
    return lhs == rhs
}

@law
fn and_distributes_over_or(p: bool, q: bool, r: bool) -> bool {
    let lhs = p and (q or r)
    let rhs = (p and q) or (p and r)
    return lhs == rhs
}

@law
fn absorption_law(p: bool, q: bool) -> bool {
    return (p or (p and q)) == p
}

// ---- List structural properties ----------------------------------

fn list_reverse(xs: list) -> list {
    let mut out = []
    let n = len(xs)
    let mut i = n - 1
    while i >= 0 {
        out = out + [xs[i]]
        i = i - 1
    }
    return out
}

@law
fn reverse_is_involutive(xs: list) -> bool {
    return list_reverse(list_reverse(xs)) == xs
}

@law
fn reverse_preserves_length(xs: list) -> bool {
    return len(list_reverse(xs)) == len(xs)
}

@law
fn concat_length_is_additive(xs: list, ys: list) -> bool {
    return len(xs + ys) == len(xs) + len(ys)
}

@law
fn concat_is_associative(xs: list, ys: list, zs: list) -> bool {
    return (xs + ys) + zs == xs + (ys + zs)
}

@law
fn empty_is_left_identity_for_concat(xs: list) -> bool {
    return [] + xs == xs
}

@law
fn empty_is_right_identity_for_concat(xs: list) -> bool {
    return xs + [] == xs
}

@law
fn singleton_append_grows_by_one(xs: list) -> bool {
    return len(xs + [42]) == len(xs) + 1
}

// ---- String properties -------------------------------------------

@law
fn string_concat_is_associative(a: str, b: str, c: str) -> bool {
    return (a + b) + c == a + (b + c)
}

@law
fn empty_string_is_identity(s: str) -> bool {
    return "" + s == s and s + "" == s
}

@law
fn string_length_additive(a: str, b: str) -> bool {
    return len(a + b) == len(a) + len(b)
}

// ---- Comparison laws (total order on ints) -----------------------

@law
fn lt_is_transitive(a: int, b: int, c: int) -> bool {
    assume(a < b)
    assume(b < c)
    return a < c
}

@law
fn lt_is_antisymmetric(a: int, b: int) -> bool {
    if a < b {
        return not (b < a)
    }
    return true
}

@law
fn eq_is_reflexive(a: int) -> bool {
    return a == a
}

@law
fn eq_is_symmetric(a: int, b: int) -> bool {
    return (a == b) == (b == a)
}

// ---- Min / max via if-expressions --------------------------------

fn imin(a: int, b: int) -> int {
    if a < b { return a }
    return b
}

fn imax(a: int, b: int) -> int {
    if a > b { return a }
    return b
}

@law
fn min_is_idempotent(a: int) -> bool {
    return imin(a, a) == a
}

@law
fn max_is_idempotent(a: int) -> bool {
    return imax(a, a) == a
}

@law
fn min_max_reconstructs_sum(a: int, b: int) -> bool {
    return imin(a, b) + imax(a, b) == a + b
}

@law
fn min_is_commutative(a: int, b: int) -> bool {
    return imin(a, b) == imin(b, a)
}

// ---- Higher-trial smoke test --------------------------------------
// Run at 1000 trials to catch corner cases in fundamental laws.

@law(trials=1000)
fn add_commutative_high_volume(a: int, b: int) -> bool {
    return a + b == b + a
}

fn main() {
    println("Canonical stdlib laws — run via: lateralus verify")
}

main()
