{h2 Chapter 7: Testing Patterns}

{h3 Recipe 7.1 — Property-Based Tests}

{code lang="lateralus"
import "testing"

-- Test a property that should hold for all inputs in a range
@property_test(runs: 1000)
fn test_sort_is_idempotent(lst: list[int]) {
    -- Sorting twice equals sorting once
    let once  = sort(lst)
    let twice = sort(once)
    assert once == twice, "sort is not idempotent"
}

@property_test(runs: 1000)
fn test_reverse_twice_is_identity(lst: list[int]) {
    assert reverse(reverse(lst)) == lst
}

@property_test(runs: 500)
fn test_pipeline_associativity(x: int) {
    -- (x |> f |> g) == (x |> (f then g))
    let f = fn n => n * 2
    let g = fn n => n + 1
    assert (x |> f |> g) == ((f then g)(x))
}
}

{h3 Recipe 7.2 — Integration Test with Fixtures}

{code lang="lateralus"
import "testing"

@fixture
fn test_db() -> dict {
    let db = {users: [], orders: []}
    yield db
    -- cleanup: db goes out of scope
}

@test
fn test_add_user(test_db: dict) {
    test_db.users = test_db.users + [{id: 1, name: "Alice"}]
    assert len(test_db.users) == 1
    assert test_db.users[0].name == "Alice"
}

@test
fn test_user_not_in_orders(test_db: dict) {
    -- Fixtures are fresh per test
    assert len(test_db.orders) == 0
}
}

