{h2 Chapter 5: Async and Concurrent Patterns}

{h3 Recipe 5.1 — Parallel Data Fetch}

{code lang="lateralus"
import "async"
import "network"

-- Fetch multiple URLs concurrently using channels
async fn fetch_all(urls: list[str]) -> list[dict] {
    let tasks = urls |> map(fn url => async {
        let resp = network.get_json(url)
        return {url: url, data: resp, ok: resp != None}
    })
    return await async.gather(tasks)
}

let urls = [
    "https://api.github.com/repos/lateralus-lang/lateralus",
    "https://api.github.com/repos/lateralus-lang/stdlib",
]

let results = await fetch_all(urls)
for r in results {
    println(r.url + ": " + (if r.ok { "OK" } else { "FAILED" }))
}
}

{h3 Recipe 5.2 — Rate-Limited API Client}

{code lang="lateralus"
import "async"

-- Process items with a rate limit (max N requests per second)
async fn process_with_rate_limit(items: list[any], handler: fn, rate: int = 10) -> list {
    let limiter = async.RateLimiter(rate: rate, per: 1.0)
    let results = []

    for item in items {
        await limiter.acquire()
        let result = await handler(item)
        results = results + [result]
    }

    return results
}
}

{h3 Recipe 5.3 — Reactive Counter with Effects}

{code lang="lateralus"
import "reactive"

let count   = Signal(0)
let doubled = Computed(fn => count.get() * 2)
let label   = Computed(fn => if count.get() == 0 { "zero" } else { "nonzero" })

-- Effect: runs whenever count changes
let eff = Effect(fn => {
    println("count=" + str(count.get()) +
            " doubled=" + str(doubled.get()) +
            " label=" + label.get())
})

count.set(1)   -- prints: count=1 doubled=2 label=nonzero
count.set(2)   -- prints: count=2 doubled=4 label=nonzero
count.set(0)   -- prints: count=0 doubled=0 label=zero

eff.dispose()  -- stop tracking
count.set(99)  -- nothing printed
}

