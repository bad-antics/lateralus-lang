// Example test module.
//
// Run with: lateralus test tests/

import testing

fn test_addition() {
    testing.assert_eq(1 + 1, 2)
}

fn test_pipeline() {
    let result = [1, 2, 3]
        |> map(fn(x) { x * 2 })
        |> sum()
    testing.assert_eq(result, 12)
}

test_addition()
test_pipeline()
