// examples/hello.ltl  -  Hello World in Lateralus Script

module examples.hello

import io

fn main() {
    let name: str = "LATERALUS"
    io.println("Hello from " + name + "!")
    io.println("Version: 1.0.0")

    // Pipeline demo
    let result = [1, 2, 3, 4, 5]
        |> map(fn(x) x * x)
        |> filter(fn(x) x > 4)

    io.println("Squares > 4: " + result as str)
}

main()
