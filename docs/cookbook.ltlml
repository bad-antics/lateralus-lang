{h1 The LATERALUS Cookbook}

{p
  This cookbook provides concise, copy-paste-ready recipes for solving common
  programming tasks in LATERALUS. Each recipe presents a problem, explains the
  approach, and gives a complete working example.
}

{toc}

{separator}

{h2 Chapter 1: Pipeline Patterns}

{h3 Recipe 1.1 — Data Transformation Pipeline}

{p
  {strong Problem}: Transform a list of raw records through multiple steps:
  filter, normalize, enrich, and format.
}

{code lang="lateralus"
let raw_data = [
    {name: "alice", score: 87, dept: "engineering"},
    {name: "bob",   score: 42, dept: "sales"},
    {name: "diana", score: 95, dept: "engineering"},
    {name: "eve",   score: 38, dept: "sales"},
]

let report = raw_data
    |> filter(fn r => r.score >= 50)           -- keep passing scores
    |> map(fn r => {
        ...r,
        name: capitalize(r.name),              -- normalize name
        grade: if r.score >= 90 { "A" }
               else if r.score >= 80 { "B" }
               else { "C" },
        passed: true
    })
    |> sort_by(fn r => -r.score)               -- best first
    |> map(fn r => r.name + ": " + r.grade)    -- format

println(report)
-- ["Diana: A", "Alice: B"]
}

{h3 Recipe 1.2 — Safe Optional Pipeline}

{p
  {strong Problem}: Process a value that might be None at any step without
  crashing or writing nested null checks.
}

{code lang="lateralus"
-- |? propagates None automatically, skipping any step that receives None
fn get_user_city(user_id: int) -> str | None {
    return fetch_user(user_id)
        |? fn u => u.address
        |? fn a => a.city
        |? fn c => c.name
}

-- If user doesn't exist or has no address, returns None silently
let city = get_user_city(999)
println(city)  -- None (no crash)
}

{h3 Recipe 1.3 — Pipeline with Error Accumulation}

{p
  {strong Problem}: Validate a form, collecting all errors rather than stopping
  at the first one.
}

{code lang="lateralus"
struct ValidationResult {
    valid: bool
    errors: list[str]
}

fn validate_form(data: dict) -> ValidationResult {
    let errors = []

    let errors = errors + if len(data.name) < 2 {
        ["Name must be at least 2 characters"]
    } else { [] }

    let errors = errors + if not data.email |> contains("@") {
        ["Invalid email address"]
    } else { [] }

    let errors = errors + if data.age < 18 {
        ["Must be 18 or older"]
    } else { [] }

    return ValidationResult {
        valid: len(errors) == 0,
        errors: errors
    }
}

let result = validate_form({name: "A", email: "bad", age: 15})
println(result.errors)
-- ["Name must be at least 2 chars", "Invalid email", "Must be 18+"]
}

{separator}

{h2 Chapter 2: Data Processing}

{h3 Recipe 2.1 — CSV Processing with Pipelines}

{p
  {strong Problem}: Load a CSV file, compute aggregates, and output results.
}

{code lang="lateralus"
import "io"
import "strings"

fn parse_csv(text: str) -> list[dict] {
    let lines = strings.split(text, "\n")
    let header = strings.split(lines[0], ",")
    return lines[1:]
        |> filter(fn l => len(l) > 0)
        |> map(fn l => {
            let values = strings.split(l, ",")
            return collections.zip_to_dict(header, values)
        })
}

let csv_text = io.read_file("data/sales.csv")
let records  = parse_csv(csv_text)

let by_region = records
    |> group_by(fn r => r["region"])
    |> map_values(fn rows => sum(map(rows, fn r => float(r["amount"]))))

println(by_region)
}

{h3 Recipe 2.2 — LQL Query on In-Memory Collections}

{p
  {strong Problem}: Filter and aggregate structured data using SQL-like syntax.
}

{code lang="lateralus"
import "query"

let users = [
    {id: 1, name: "Alice", dept: "eng",   salary: 95000},
    {id: 2, name: "Bob",   dept: "eng",   salary: 75000},
    {id: 3, name: "Carol", dept: "sales", salary: 80000},
]

-- Using the fluent API
let engineers = Query.from(users)
    .where(fn u => u.dept == "eng")
    .order_by("salary", ascending: false)
    .select("name", "salary")
    .execute()

println(engineers)

-- Using LQL string syntax
let result = lql("SELECT * FROM users WHERE dept = 'eng' ORDER BY salary DESC", {users: users})
println(result)
}

{h3 Recipe 2.3 — JSON API Response Processing}

{p
  {strong Problem}: Fetch data from a REST API, extract fields, and reformat.
}

{code lang="lateralus"
import "network"
import "json"

let response = network.get_json("https://api.example.com/users")

let active_users = response["data"]
    |> filter(fn u => u["active"] == true)
    |> map(fn u => {
        id:    u["id"],
        name:  u["firstName"] + " " + u["lastName"],
        email: u["email"]
    })
    |> sort_by(fn u => u.name)

json.save_file("output/active_users.json", active_users)
println("Saved " + str(len(active_users)) + " active users")
}

{separator}

{h2 Chapter 3: Pattern Matching}

{h3 Recipe 3.1 — Algebraic Data Type Dispatch}

{p
  {strong Problem}: Process a tree-like structure using exhaustive pattern matching.
}

{code lang="lateralus"
-- A simple expression tree
struct Num   { value: float }
struct Add   { left: any, right: any }
struct Mul   { left: any, right: any }
struct Neg   { expr: any }

fn eval(expr: any) -> float {
    match expr {
        Num   { value } => value,
        Add   { left, right } => eval(left) + eval(right),
        Mul   { left, right } => eval(left) * eval(right),
        Neg   { expr: e }    => -eval(e),
        _                    => 0.0
    }
}

-- (3 + 4) * -2 = -14
let tree = Mul {
    left:  Add { left: Num{3.0}, right: Num{4.0} },
    right: Neg { expr: Num{2.0} }
}

println(eval(tree))  -- -14.0
}

{h3 Recipe 3.2 — HTTP Status Code Handler}

{p
  {strong Problem}: Handle different HTTP response status codes cleanly.
}

{code lang="lateralus"
fn handle_response(status: int, body: str) -> str {
    match status {
        200 => "OK: " + body,
        201 => "Created: " + body,
        400 => "Bad request: " + body,
        401 => "Unauthorized — check your API key",
        403 => "Forbidden",
        404 => "Not found",
        429 => "Rate limited — retry after 60s",
        500 | 502 | 503 => "Server error: " + body,
        n if n >= 200 and n < 300 => "Success (2xx): " + body,
        n if n >= 400 and n < 500 => "Client error " + str(n),
        _ => "Unknown status " + str(status)
    }
}
}

{h3 Recipe 3.3 — Parsing Command-Line Arguments}

{code lang="lateralus"
fn parse_args(args: list[str]) -> dict {
    let result = {verbose: false, output: "stdout", files: []}
    let i = 0

    while i < len(args) {
        match args[i] {
            "--verbose" | "-v" => {
                result = {...result, verbose: true}
                i = i + 1
            },
            "--output" | "-o" => {
                result = {...result, output: args[i + 1]}
                i = i + 2
            },
            flag if starts_with(flag, "--") => {
                println("Unknown flag: " + flag)
                i = i + 1
            },
            file => {
                result = {...result, files: result.files + [file]}
                i = i + 1
            }
        }
    }

    return result
}
}

{separator}

{h2 Chapter 4: Scientific Computing}

{h3 Recipe 4.1 — Physics Simulation: Projectile Motion}

{code lang="lateralus"
import "science"
import "math"

-- Simulate projectile: position over time with air resistance
struct State {
    x: float
    y: float
    vx: float
    vy: float
}

let g   = science.constants.G_STANDARD   -- 9.80665 m/s²
let rho = 1.225                           -- air density kg/m³
let Cd  = 0.47                            -- drag coeff (sphere)
let A   = 0.01                            -- cross-section m²
let m   = 0.145                           -- mass kg (baseball)

fn drag(v: float) -> float {
    return 0.5 * rho * Cd * A * v * v / m
}

fn projectile_ode(t: float, state: list[float]) -> list[float] {
    let x, y, vx, vy = state
    let speed = math.sqrt(vx * vx + vy * vy)
    let dvx = -drag(speed) * vx / speed if speed > 0.001 else 0.0
    let dvy = -g - (drag(speed) * vy / speed if speed > 0.001 else 0.0)
    return [vx, vy, dvx, dvy]
}

-- Launch at 45° with 30 m/s
let v0 = 30.0
let angle = math.PI / 4.0
let s0 = [0.0, 0.0, v0 * math.cos(angle), v0 * math.sin(angle)]

let trajectory = science.ode_rk4(projectile_ode, 0.0, 3.0, s0, dt: 0.01)
let landing = first(filter(trajectory, fn s => s[1] < 0.0))
println("Range: " + str(landing[0]) + " m")
}

{h3 Recipe 4.2 — Statistical Analysis Pipeline}

{code lang="lateralus"
import "science"
import "stats"

let data = [23.1, 25.4, 22.8, 24.7, 26.1, 21.9, 25.0, 24.3, 23.7, 25.8]

let analysis = {
    n:       len(data),
    mean:    stats.mean(data),
    std:     stats.std(data),
    median:  stats.median(data),
    min:     min(data),
    max:     max(data),
    cv:      stats.std(data) / stats.mean(data) * 100.0,  -- coefficient of variation
    ci_95:   stats.confidence_interval(data, 0.95)
}

-- Pretty print
for key, val in analysis.items() {
    println(key + ": " + str(round(val, 4) if type(val) == float else val))
}

-- Normality test (Shapiro-Wilk approximation)
let is_normal = science.shapiro_wilk_approx(data).p_value > 0.05
println("Data appears normal: " + str(is_normal))
}

{h3 Recipe 4.3 — Matrix Operations for Machine Learning}

{code lang="lateralus"
import "linalg"

-- Simple linear regression: y = Xw using least squares
fn linear_regression(X: Matrix, y: Vector) -> Vector {
    -- w = (X^T X)^{-1} X^T y
    let Xt  = linalg.transpose(X)
    let XtX = linalg.matmul(Xt, X)
    let Xty = linalg.matmul(Xt, linalg.col_vector(y))
    return linalg.solve(XtX, Xty)
}

-- Feature matrix: [1, x] (bias + single feature)
let X = linalg.matrix_from_rows([
    [1.0, 1.0],
    [1.0, 2.0],
    [1.0, 3.0],
    [1.0, 4.0],
    [1.0, 5.0],
])
let y = [2.1, 4.0, 5.9, 8.1, 10.0]

let weights = linear_regression(X, y)
println("Intercept: " + str(weights[0]))
println("Slope: " + str(weights[1]))
}

