{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lateralus Notebook",
  "scopeName": "source.ltlnb",
  "fileTypes": ["ltlnb"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#null" },
    { "include": "#keys" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "comments": {
      "name": "comment.line.double-slash.ltlnb",
      "match": "//.*$"
    },

    "strings": {
      "name": "string.quoted.double.ltlnb",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.ltlnb" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.ltlnb" } },
      "patterns": [
        {
          "name": "constant.character.escape.ltlnb",
          "match": "\\\\(?:[\"\\\\bfnrt/]|u[0-9A-Fa-f]{4})"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ltlnb",
          "match": "-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?"
        },
        {
          "name": "constant.numeric.integer.ltlnb",
          "match": "-?(?:0|[1-9]\\d*)"
        }
      ]
    },

    "booleans": {
      "name": "constant.language.boolean.ltlnb",
      "match": "\\b(true|false)\\b"
    },

    "null": {
      "name": "constant.language.null.ltlnb",
      "match": "\\bnull\\b"
    },

    "keys": {
      "name": "meta.key-value.ltlnb",
      "match": "(\"(?:lateralus_version|cells|cell_type|source|outputs|metadata|execution_count|kernel|language|title|author|created|modified)\")\\s*(:)",
      "captures": {
        "1": { "name": "support.type.property-name.ltlnb" },
        "2": { "name": "punctuation.separator.key-value.ltlnb" }
      }
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.array.begin.ltlnb",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.array.end.ltlnb",
          "match": "\\]"
        },
        {
          "name": "punctuation.definition.object.begin.ltlnb",
          "match": "\\{"
        },
        {
          "name": "punctuation.definition.object.end.ltlnb",
          "match": "\\}"
        },
        {
          "name": "punctuation.separator.comma.ltlnb",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.ltlnb",
          "match": ":"
        }
      ]
    }
  }
}
