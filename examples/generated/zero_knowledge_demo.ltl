import math / import strings / import crypto / import io


// ─── Section: Defining Helper Functions ───────────────────────────────────────
fn gcd(a: int, b: int): int {
    if b == 0 {
        return a;
    } else {
        return gcd(b, a % b);
    }
}

fn mod_inverse(a: int, m: int) -> int {
    let g = gcd(a, m);
    if g != 1 {
        panic!("Modular inverse does not exist");
    } else {
        return pow_mod(a, m - 2, m);
    }
}

fn pow_mod(base: int, exponent: int, modulus: int) -> int {
    let result = 1;
    base %= modulus;
    while exponent > 0 {
        if exponent & 1 == 1 {
            result = (result * base) % modulus;
        }
        exponent >>= 1;
        base = (base * base) % modulus;
    }
    return result;
}

// ─── Section: Main Zero-Knowledge Proof Function ────────────────────────────────
async fn schnorr_proof(
    public_key: str,
    private_key: str,
    message: str,
    commitment: str,
    proof: str
) -> str {
    // Extract the public and private components of the key pair
    let public_component = extract_public(public_key);
    let private_component = extract_private(private_key);

    // Compute the hash of the message using the public component
    let message_hash = crypto::hash(message, public_component);

    // Verify that the proof is valid using the private component and the message hash
    let proof_validity = verify_proof(proof, message_hash, private_component);

    if !proof_validity {
        panic!("Proof is invalid");
    }

    // Return a success message
    return "Proof is valid";
}

