// ===================================================================
// tests/stdlib_spiral_wave_8.ltl
// Columnar / analytical: run_length, dict_encoding, frame_of_reference,
// arrow_ipc, parquet.
// ===================================================================

let PASS = 0
let FAIL = 0

fn check(name: str, cond: bool) {
    if cond {
        PASS = PASS + 1
        print("  ok  " + name)
    } else {
        FAIL = FAIL + 1
        print("  FAIL " + name)
    }
}

fn lists_equal(a: list, b: list) -> bool {
    if len(a) != len(b) { return false }
    let i = 0
    while i < len(a) {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn test_rle() {
    print("[run_length]")
    let xs = [1,1,1,2,2,3,3,3,3,4]
    let p = run_length_encode_pairs(xs)
    check("4 runs", len(p) == 4)
    check("first run [1,3]", p[0][0] == 1 && p[0][1] == 3)
    check("rt", lists_equal(run_length_decode_pairs(p), xs))
    let pk = run_length_encode_packed(xs)
    check("packed rt", lists_equal(run_length_decode_packed(pk), xs))
    check("empty rt", lists_equal(run_length_decode_pairs(run_length_encode_pairs([])), []))
}

fn test_dict() {
    print("[dict_encoding]")
    let vs = ["a","b","a","c","b","a"]
    let e = dict_encoding_encode(vs)
    check("card 3", dict_encoding_cardinality(e) == 3)
    check("bits 2", dict_encoding_index_bit_width(e) == 2)
    check("rt",     lists_equal(dict_encoding_decode(e), vs))
    let mono = dict_encoding_encode(["x"])
    check("mono bits=1", dict_encoding_index_bit_width(mono) == 1)
}

fn test_for() {
    print("[frame_of_reference]")
    let xs = [1000, 1001, 1002, 1010, 1003]
    let e = frame_of_reference_encode(xs)
    check("ref = 1000", e["ref"] == 1000)
    check("max delta = 10",
          e["deltas"][3] == 10)
    check("bw = 4", e["bit_width"] == 4)
    check("rt", lists_equal(frame_of_reference_decode(e), xs))

    let ts = [100, 110, 120, 131, 140]
    let d = frame_of_reference_encode_dod(ts)
    check("dod first", d["first"] == 100)
    check("dod second_delta", d["second_delta"] == 10)
    let back = frame_of_reference_decode_dod(d)
    check("dod rt", lists_equal(back, ts))
}

fn test_arrow() {
    print("[arrow_ipc]")
    let frame = arrow_ipc_frame_message([1,2,3,4], [9,9,9])
    check("frame ≥ 16B", len(frame) >= 16)
    let h = arrow_ipc_parse_frame_header(frame, 0)
    check("metadata_len = 8 (padded)", h["metadata_len"] == 8)
    let bm = arrow_ipc_validity_bitmap([true, false, true, true, false, false, true, true, true])
    // bits: 10110011 1 → byte0=0xCD, byte1=0x01
    check("bitmap byte0", bm[0] == 0xCD)
    check("bitmap byte1", bm[1] == 0x01)
    check("bitmap padded to 8", len(bm) == 8)
    let bufs = arrow_ipc_buffers_utf8(["ab","","cdef"])
    // offsets: 0,2,2,6 → 16 bytes raw, padded to 16
    check("utf8 offsets len", len(bufs[0]) == 16)
    check("utf8 data len padded", len(bufs[1]) == 8)
}

fn test_parquet() {
    print("[parquet]")
    let body = [1,2,3,4,5,6,7,8]
    let footer = [9,9,9,9]
    let f = parquet_assemble_file(body, footer)
    // PAR1(4) + body(8) + footer(4) + i32 len(4) + PAR1(4) = 24
    check("file = 24B", len(f) == 24)
    check("starts PAR1", f[0] == 0x50 && f[3] == 0x31)
    check("ends PAR1",   f[len(f)-4] == 0x50 && f[len(f)-1] == 0x31)
    let fp = parquet_parse_footer_pointer(f)
    check("footer_len = 4", fp["footer_len"] == 4)
    check("footer_offset = 12", fp["footer_offset"] == 12)
    // Thrift compact varint: zz(0)=0, zz(-1)=1, zz(1)=2
    check("zz(0)=0",  parquet_thrift_zz_i32(0) == 0)
    check("zz(-1)=1", parquet_thrift_zz_i32(-1) == 1)
    check("zz(1)=2",  parquet_thrift_zz_i32(1) == 2)
    let v300 = parquet_thrift_uvarint(300)   // 0xAC, 0x02
    check("uvarint 300 = AC,02",
          len(v300) == 2 && v300[0] == 0xAC && v300[1] == 0x02)
}

fn main() {
    print("=== Spiral Wave 8 — columnar ===")
    test_rle(); test_dict(); test_for(); test_arrow(); test_parquet()
    print("---"); print("pass=" + str(PASS) + " fail=" + str(FAIL))
}
main()
