{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lateralus Assembly",
  "scopeName": "source.ltasm",
  "fileTypes": ["ltasm"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#directives" },
    { "include": "#labels" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#registers" },
    { "include": "#opcodes" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "comments": {
      "name": "comment.line.semicolon.ltasm",
      "match": ";.*$"
    },

    "directives": {
      "name": "keyword.control.directive.ltasm",
      "match": "^\\s*(\\.(?:section|global|data|text|bss|string|byte|word|dword|qword|ascii|zero|align|space))\\b",
      "captures": {
        "1": { "name": "keyword.control.directive.ltasm" }
      }
    },

    "labels": {
      "patterns": [
        {
          "name": "entity.name.function.label.ltasm",
          "match": "^([A-Za-z_][A-Za-z0-9_]*)(?=:)",
          "captures": {
            "1": { "name": "entity.name.function.label.ltasm" }
          }
        },
        {
          "name": "entity.name.label.reference.ltasm",
          "match": "\\.[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.ltasm",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.ltasm" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.ltasm" } },
      "patterns": [
        {
          "name": "constant.character.escape.ltasm",
          "match": "\\\\[ntr\\\\\"0]"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.ltasm",
          "match": "\\b0[xX][0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary.ltasm",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.integer.ltasm",
          "match": "\\b-?[0-9][0-9_]*\\b"
        }
      ]
    },

    "registers": {
      "name": "variable.language.register.ltasm",
      "match": "\\b(r(?:1[0-5]|[0-9])|sp|pc|flags)\\b"
    },

    "opcodes": {
      "name": "keyword.other.opcode.ltasm",
      "match": "\\b(NOP|PUSH_IMM|PUSH_STR|PUSH_REG|POP|POP_REG|DUP|DUP2|SWAP|ADD|SUB|MUL|DIV|MOD|POW|NEG|INC|DEC|FADD|FSUB|FMUL|FDIV|AND|OR|XOR|NOT|SHL|SHR|CMP|CMPEQ|CMPNE|CMPLT|CMPLE|CMPGT|CMPGE|JMP|JT|JF|JZ|JNZ|CALL|RET|CALL_REG|TAIL_CALL|HALT|LOAD|STORE|LOAD_IDX|STORE_IDX|MOV|MOV_IMM|LEA|ALLOC|FREE|GCPAUSE|SIZEOF_OP|INT_TO_F|F_TO_INT|INT_TO_STR|F_TO_STR|STR_TO_INT|STR_TO_F|TYPEOF_OP|STR_CAT|STR_LEN|STR_SLICE|LIST_NEW|LIST_PUSH|LIST_POP|LIST_LEN|LIST_GET|LIST_SET|MAP_NEW|MAP_GET|MAP_SET|MAP_HAS|MAP_DEL|MAP_KEYS|PRINT|PRINTLN|READ_LINE|READ_INT|READ_FLOAT|FLUSH|SYSCALL|FOREIGN|SPAWN|AWAIT_OP|YIELD|SLEEP|TRY_BEGIN|TRY_END|THROW|THROW_STR|ENSURE_BEG|ENSURE_END|RETHROW|BREAKPOINT|TRACE|ASSERT|DUMP_STACK|DUMP_REGS|PUSH|PUSH\\.REG|PUSH\\.STR|JLE|JGE|CALL\\.REG|MOV\\.IMM|EQ|NE|LT|LE|GT|GE|LOAD_REG|STORE_REG|SWAP)\\b"
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.ltasm",
          "match": ","
        },
        {
          "name": "punctuation.definition.label.colon.ltasm",
          "match": ":"
        }
      ]
    }
  }
}
