// ═══════════════════════════════════════════════════════════════════
// LATERALUS v3.2 — Mutation-testing demo
// ═══════════════════════════════════════════════════════════════════
// Run:   lateralus verify tests/laws/mutation_demo.ltl --mutate
//
// Every function below is covered by an @law that pins down its
// behavior tightly enough that any mutation should be caught.
// A mutation score below 100 % means a law is missing.
// ═══════════════════════════════════════════════════════════════════

fn add(a: int, b: int) -> int {
    return a + b
}

fn mul(a: int, b: int) -> int {
    return a * b
}

fn max2(a: int, b: int) -> int {
    if a > b {
        return a
    }
    return b
}

fn min2(a: int, b: int) -> int {
    if a < b {
        return a
    }
    return b
}

fn is_positive(x: int) -> bool {
    return x > 0
}

// ─── Laws ──────────────────────────────────────────────────────────

@law
fn add_is_commutative(a: int, b: int) -> bool {
    return add(a, b) == add(b, a)
}

@law
fn add_is_associative(a: int, b: int, c: int) -> bool {
    return add(add(a, b), c) == add(a, add(b, c))
}

@law
fn add_has_identity(a: int) -> bool {
    return add(a, 0) == a
}

@law
fn mul_is_commutative(a: int, b: int) -> bool {
    return mul(a, b) == mul(b, a)
}

@law
fn mul_distributes_over_add(a: int, b: int, c: int) -> bool {
    return mul(a, add(b, c)) == add(mul(a, b), mul(a, c))
}

@law
fn mul_has_identity(a: int) -> bool {
    return mul(a, 1) == a
}

@law
fn mul_absorbs_zero(a: int) -> bool {
    return mul(a, 0) == 0
}

@law
fn max2_is_at_least(a: int, b: int) -> bool {
    let m = max2(a, b)
    return m >= a and m >= b
}

@law
fn max2_picks_one(a: int, b: int) -> bool {
    let m = max2(a, b)
    return m == a or m == b
}

@law
fn min2_is_at_most(a: int, b: int) -> bool {
    let m = min2(a, b)
    return m <= a and m <= b
}

@law
fn min2_picks_one(a: int, b: int) -> bool {
    let m = min2(a, b)
    return m == a or m == b
}

@law
fn max_min_together_equal_sum(a: int, b: int) -> bool {
    return add(max2(a, b), min2(a, b)) == add(a, b)
}

@law
fn is_positive_of_positive(a: int) -> bool {
    assume(a > 0)
    return is_positive(a) == true
}

@law
fn is_positive_of_zero() -> bool {
    return is_positive(0) == false
}

@law
fn is_positive_of_negative(a: int) -> bool {
    assume(a < 0)
    return is_positive(a) == false
}
