// Binary trees — allocation-heavy benchmark
struct Tree {
    left: any,
    right: any,
}

fn make(depth: int) -> any {
    if depth == 0 {
        return 0
    }
    let l = make(depth - 1)
    let r = make(depth - 1)
    return Tree { left: l, right: r }
}

fn check(node: any) -> int {
    if node == 0 {
        return 1
    }
    return 1 + check(node.left) + check(node.right)
}

fn main() {
    let depth = 12
    let t = make(depth)
    let c = check(t)
    println(c)
}

main()
