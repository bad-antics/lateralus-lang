# Maintainer: bad-antics <hello@lateralus.dev>
pkgname=lateralus-lang
pkgver=3.2.0
pkgrel=1
pkgdesc="Lateralus programming language — compiler, LSP, formatter"
arch=('any')
url="https://lateralus.dev"
license=('MIT')
depends=('python>=3.10')
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
source=("https://files.pythonhosted.org/packages/source/l/lateralus-lang/lateralus_lang-${pkgver}.tar.gz")
sha256sums=('a6a3e5da2ccfe2d8dc5d82e359484337ca4e9532dcf7631bee7f2a41a59dd5a0')

build() {
  cd "lateralus_lang-${pkgver}"
  python -m build --wheel --no-isolation
}

package() {
  cd "lateralus_lang-${pkgver}"
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 LICENSE-FREEWARE.md "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null \
    || install -Dm644 LICENSE     "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null \
    || true
}
