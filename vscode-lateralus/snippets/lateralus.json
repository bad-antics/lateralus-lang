{
  "Lateralus Module Declaration": {
    "prefix": "module",
    "body": ["module ${1:name}"],
    "description": "Declare a module"
  },
  "Lateralus Import": {
    "prefix": "import",
    "body": ["import ${1:module}"],
    "description": "Import a module"
  },
  "Lateralus From Import": {
    "prefix": "from",
    "body": ["from ${1:module} import ${2:symbol}"],
    "description": "Import a symbol from a module"
  },
  "Lateralus Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:void} {",
      "\t${0}",
      "}"
    ],
    "description": "Define a function"
  },
  "Lateralus Async Function": {
    "prefix": "afn",
    "body": [
      "async fn ${1:name}(${2:params}) -> ${3:void} {",
      "\t${0}",
      "}"
    ],
    "description": "Define an async function"
  },
  "Lateralus Let": {
    "prefix": "let",
    "body": ["let ${1:name}: ${2:type} = ${0}"],
    "description": "Declare a variable"
  },
  "Lateralus Mutable Let": {
    "prefix": "letm",
    "body": ["let mut ${1:name}: ${2:type} = ${0}"],
    "description": "Declare a mutable variable"
  },
  "Lateralus Const": {
    "prefix": "const",
    "body": ["const ${1:NAME}: ${2:type} = ${0}"],
    "description": "Declare a constant"
  },
  "Lateralus If": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "\t${0}",
      "}"
    ],
    "description": "If statement"
  },
  "Lateralus If-Else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} {",
      "\t${2}",
      "} else {",
      "\t${0}",
      "}"
    ],
    "description": "If-else statement"
  },
  "Lateralus If-Elif-Else": {
    "prefix": "ifee",
    "body": [
      "if ${1:condition} {",
      "\t${2}",
      "} elif ${3:condition} {",
      "\t${4}",
      "} else {",
      "\t${0}",
      "}"
    ],
    "description": "If-elif-else chain"
  },
  "Lateralus Match": {
    "prefix": "match",
    "body": [
      "match ${1:value} {",
      "\t${2:pattern} => ${0}",
      "}"
    ],
    "description": "Match expression"
  },
  "Lateralus While": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "\t${0}",
      "}"
    ],
    "description": "While loop"
  },
  "Lateralus For": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iterable} {",
      "\t${0}",
      "}"
    ],
    "description": "For-in loop"
  },
  "Lateralus Loop": {
    "prefix": "loop",
    "body": [
      "loop {",
      "\t${0}",
      "}"
    ],
    "description": "Infinite loop"
  },
  "Lateralus Try-Recover": {
    "prefix": "try",
    "body": [
      "try {",
      "\t${1}",
      "} recover ${2:err} {",
      "\t${0}",
      "}"
    ],
    "description": "Try-recover block"
  },
  "Lateralus Try-Recover-Ensure": {
    "prefix": "trye",
    "body": [
      "try {",
      "\t${1}",
      "} recover ${2:err} {",
      "\t${3}",
      "} ensure {",
      "\t${0}",
      "}"
    ],
    "description": "Try-recover-ensure block"
  },
  "Lateralus Struct": {
    "prefix": "struct",
    "body": [
      "pub struct ${1:Name} {",
      "\t${2:field}: ${3:type}",
      "}"
    ],
    "description": "Define a struct"
  },
  "Lateralus Enum": {
    "prefix": "enum",
    "body": [
      "pub enum ${1:Name} {",
      "\t${2:Variant}",
      "}"
    ],
    "description": "Define an enum"
  },
  "Lateralus Impl": {
    "prefix": "impl",
    "body": [
      "impl ${1:Type} {",
      "\t${0}",
      "}"
    ],
    "description": "Impl block"
  },
  "Lateralus Impl For Interface": {
    "prefix": "implfor",
    "body": [
      "impl ${1:Interface} for ${2:Type} {",
      "\t${0}",
      "}"
    ],
    "description": "Impl interface for type"
  },
  "Lateralus Interface": {
    "prefix": "interface",
    "body": [
      "interface ${1:Name} {",
      "\t${0}",
      "}"
    ],
    "description": "Define an interface"
  },
  "Lateralus Type Alias": {
    "prefix": "type",
    "body": ["pub type ${1:Alias} = ${0:BaseType}"],
    "description": "Type alias"
  },
  "Lateralus Println": {
    "prefix": "pln",
    "body": ["println(${1:\"${0}\"})"],
    "description": "println call"
  },
  "Lateralus Return": {
    "prefix": "ret",
    "body": ["return ${0}"],
    "description": "Return statement"
  },
  "Lateralus Spawn": {
    "prefix": "spawn",
    "body": ["let ${1:handle} = spawn ${0:func()}"],
    "description": "Spawn a concurrent task"
  },
  "Lateralus Await": {
    "prefix": "await",
    "body": ["let ${1:result} = await ${0}"],
    "description": "Await an async value"
  },
  "Lateralus Pipeline": {
    "prefix": "pipe",
    "body": [
      "${1:data}",
      "\t|> ${2:transform}",
      "\t|> ${0}"
    ],
    "description": "Pipeline expression chain (|>)"
  },
  "Lateralus Pipeline Optional": {
    "prefix": "pipeopt",
    "body": [
      "${1:data}",
      "\t|> ${2:transform}",
      "\t|? ${0:fallback}"
    ],
    "description": "Pipeline with optional fallback (|?)"
  },
  "Lateralus Guard": {
    "prefix": "guard",
    "body": [
      "guard ${1:condition} else {",
      "\t${0:return}",
      "}"
    ],
    "description": "Guard clause with early return"
  },
  "Lateralus Foreign Function": {
    "prefix": "foreign",
    "body": [
      "foreign fn ${1:name}(${2:params}) -> ${0:type}"
    ],
    "description": "Declare a foreign function (FFI)"
  },
  "Lateralus Probe": {
    "prefix": "probe",
    "body": [
      "@probe(\"${1:label}\")",
      "${0}"
    ],
    "description": "Attach a probe decorator for observability"
  },
  "Lateralus Measure": {
    "prefix": "measure",
    "body": [
      "measure \"${1:label}\" {",
      "\t${0}",
      "}"
    ],
    "description": "Measure execution time of a block"
  },
  "Lateralus Where Clause": {
    "prefix": "where",
    "body": [
      "where ${1:T}: ${0:Interface}"
    ],
    "description": "Generic type constraint (where clause)"
  },
  "Lateralus Emit": {
    "prefix": "emit",
    "body": [
      "emit ${1:event}(${0:data})"
    ],
    "description": "Emit a reactive event"
  },
  "Lateralus Result Ok": {
    "prefix": "ok",
    "body": ["Result::Ok(${0:value})"],
    "description": "Wrap value in Result::Ok"
  },
  "Lateralus Result Err": {
    "prefix": "err",
    "body": ["Result::Err(${0:error})"],
    "description": "Wrap value in Result::Err"
  },
  "Lateralus Option Some": {
    "prefix": "some",
    "body": ["Option::Some(${0:value})"],
    "description": "Wrap value in Option::Some"
  },
  "Lateralus Option None": {
    "prefix": "none",
    "body": ["Option::None"],
    "description": "Option::None"
  },
  "Lateralus Match Result": {
    "prefix": "matchr",
    "body": [
      "match ${1:result} {",
      "\tResult::Ok(${2:val}) => ${3}",
      "\tResult::Err(${4:e}) => ${0}",
      "}"
    ],
    "description": "Match on a Result type"
  },
  "Lateralus Match Option": {
    "prefix": "matcho",
    "body": [
      "match ${1:opt} {",
      "\tOption::Some(${2:val}) => ${3}",
      "\tOption::None => ${0}",
      "}"
    ],
    "description": "Match on an Option type"
  },
  "Lateralus Generic Function": {
    "prefix": "fng",
    "body": [
      "fn ${1:name}<${2:T}>(${3:params}) -> ${4:T} where ${2:T}: ${5:Interface} {",
      "\t${0}",
      "}"
    ],
    "description": "Generic function with type constraint"
  },
  "Lateralus Trait Bound Function": {
    "prefix": "fntb",
    "body": [
      "fn ${1:name}<${2:T}: ${3:Comparable}>(${4:params}) -> ${5:T} {",
      "\t${0}",
      "}"
    ],
    "description": "Function with inline trait bound <T: Trait>"
  },
  "Lateralus Optional Type": {
    "prefix": "opt",
    "body": ["let ${1:name}: ${2:int}? = ${0}"],
    "description": "Optional type variable (T?)"
  },
  "Lateralus C Transpile": {
    "prefix": "ltlc",
    "body": [
      "// Transpile to C:  lateralus c ${TM_FILENAME_BASE}.ltl -o ${TM_FILENAME_BASE}.c",
      "// Compile:         gcc -O2 ${TM_FILENAME_BASE}.c -o ${TM_FILENAME_BASE}",
      "${0}"
    ],
    "description": "C backend transpilation comment"
  },
  "Lateralus Test Function": {
    "prefix": "test",
    "body": [
      "@test",
      "fn test_${1:name}() {",
      "\tassert_eq(${2:actual}, ${0:expected})",
      "}"
    ],
    "description": "Define a test function"
  },
  "Lateralus Yield": {
    "prefix": "yield",
    "body": ["yield ${0:value}"],
    "description": "Yield a value from a generator"
  },
  "Lateralus Main Function": {
    "prefix": "main",
    "body": [
      "fn main() {",
      "\t${0}",
      "}"
    ],
    "description": "Main entry point function"
  }
}
