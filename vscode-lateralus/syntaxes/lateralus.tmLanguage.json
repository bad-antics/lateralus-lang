{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lateralus",
  "scopeName": "source.ltl",
  "fileTypes": ["ltl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#decorators" },
    { "include": "#adt-variants" },
    { "include": "#strings" },
    { "include": "#raw-strings" },
    { "include": "#char-literals" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtin-types" },
    { "include": "#builtin-values" },
    { "include": "#builtin-functions" },
    { "include": "#function-definition" },
    { "include": "#struct-enum-definition" },
    { "include": "#impl-interface-definition" },
    { "include": "#module-import" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ltl",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.ltl",
          "match": "#.*$"
        },
        {
          "name": "comment.block.ltl",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.ltl" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.ltl" } }
        }
      ]
    },

    "decorators": {
      "name": "meta.decorator.ltl",
      "match": "(@)([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.decorator.ltl" },
        "2": { "name": "entity.name.function.decorator.ltl" }
      }
    },

    "strings": {
      "name": "string.quoted.double.ltl",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.ltl" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.ltl" } },
      "patterns": [
        {
          "name": "constant.character.escape.ltl",
          "match": "\\\\[ntr\\\\\"0]"
        },
        {
          "name": "meta.interpolation.ltl",
          "begin": "(?<!\\{)\\{(?!\\{)",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.ltl" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.interpolation.end.ltl" } },
          "patterns": [
            { "include": "#keywords" },
            { "include": "#numbers" },
            { "include": "#operators" },
            { "include": "#identifiers" }
          ]
        }
      ]
    },

    "raw-strings": {
      "name": "string.quoted.double.raw.ltl",
      "begin": "r\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.ltl" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.ltl" } }
    },

    "char-literals": {
      "name": "string.quoted.single.ltl",
      "match": "'(?:\\\\[ntr\\\\\"0]|[^\\\\'])'",
      "captures": { "0": { "name": "constant.character.ltl" } }
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.ltl",
          "match": "\\b0[xX][0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary.ltl",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.float.ltl",
          "match": "\\b[0-9][0-9_]*(?:\\.[0-9][0-9_]*)?(?:[eE][+-]?[0-9]+)?\\b"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ltl",
          "match": "\\b(if|elif|else|match|while|loop|for|in|break|continue|return|try|recover|ensure|yield|throw|pass|guard|where)\\b"
        },
        {
          "name": "keyword.declaration.ltl",
          "match": "\\b(fn|async|await|let|const|mut|pub|struct|enum|type|impl|interface|trait|spawn|foreign|emit|probe|measure)\\b"
        },
        {
          "name": "keyword.other.ltl",
          "match": "\\b(module|import|from|as|typeof|sizeof|not|and|or|self)\\b"
        }
      ]
    },

    "builtin-types": {
      "patterns": [
        {
          "name": "meta.type.optional.ltl",
          "match": "\\b(int|float|str|bool|char|any|void|fn|Result|Option)\\?",
          "captures": {
            "1": { "name": "support.type.ltl" }
          }
        },
        {
          "name": "support.type.ltl",
          "match": "\\b(int|float|str|bool|char|any|void|fn|Result|Option|Iterator|Comparable|Hashable)\\b"
        }
      ]
    },

    "builtin-values": {
      "name": "constant.language.ltl",
      "match": "\\b(true|false|nil|none)\\b"
    },

    "adt-variants": {
      "name": "meta.adt-variant.ltl",
      "match": "\\b(Result|Option)::(Ok|Err|Some|None)\\b",
      "captures": {
        "1": { "name": "support.type.ltl" },
        "2": { "name": "constant.language.ltl" }
      }
    },

    "builtin-functions": {
      "name": "support.function.builtin.ltl",
      "match": "\\b(println|print|str|len|push|pop|map|filter|foldl|zip|chunk|sort|reverse|enumerate_list|range|contains|next|sleep_ms|list_copy|list_set|slice_list|repeat_str|sqrt|abs|min|max|sum|keys|values|split|join|type|int|float|hash_sha256|hash_blake2b|random_token|base64_encode|base64_decode|assert_eq)\\b"
    },

    "function-definition": {
      "name": "meta.function.ltl",
      "match": "\\b(async\\s+)?\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "keyword.declaration.ltl" },
        "2": { "name": "keyword.declaration.ltl" },
        "3": { "name": "entity.name.function.ltl" }
      }
    },

    "struct-enum-definition": {
      "name": "meta.type-declaration.ltl",
      "match": "\\b(pub\\s+)?(struct|enum|type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.ltl" },
        "2": { "name": "keyword.declaration.ltl" },
        "3": { "name": "entity.name.type.ltl" }
      }
    },

    "impl-interface-definition": {
      "name": "meta.impl.ltl",
      "match": "\\b(impl|interface)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(for)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
      "captures": {
        "1": { "name": "keyword.declaration.ltl" },
        "2": { "name": "entity.name.type.ltl" },
        "3": { "name": "keyword.other.ltl" },
        "4": { "name": "entity.name.type.ltl" }
      }
    },

    "module-import": {
      "patterns": [
        {
          "name": "meta.module.ltl",
          "match": "\\b(module)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.other.ltl" },
            "2": { "name": "entity.name.namespace.ltl" }
          }
        },
        {
          "name": "meta.import.ltl",
          "match": "\\b(import|from)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.other.ltl" },
            "2": { "name": "entity.name.namespace.ltl" }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipeline.ltl",
          "match": "\\|>=|\\|>|\\|\\?"
        },
        {
          "name": "keyword.operator.spread.ltl",
          "match": "\\.\\.\\."  
        },
        {
          "name": "keyword.operator.scope.ltl",
          "match": "::"
        },
        {
          "name": "keyword.operator.arrow.ltl",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.range.ltl",
          "match": "\\.\\.<|\\.\\."
        },
        {
          "name": "keyword.operator.arithmetic.ltl",
          "match": "\\*\\*=|\\*\\*|\\+=|-=|\\*=|/=|%=|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.comparison.ltl",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.ltl",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.ltl",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.assignment.ltl",
          "match": "="
        },
        {
          "name": "keyword.operator.nullable.ltl",
          "match": "\\?"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.ltl",
          "match": ","
        },
        {
          "name": "punctuation.terminator.semicolon.ltl",
          "match": ";"
        },
        {
          "name": "punctuation.separator.colon.ltl",
          "match": ":"
        },
        {
          "name": "punctuation.accessor.dot.ltl",
          "match": "\\."
        },
        {
          "name": "punctuation.bracket.ltl",
          "match": "[(){}\\[\\]]"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.constant.ltl",
          "match": "\\b[A-Z][A-Z0-9_]+\\b"
        },
        {
          "name": "entity.name.type.ltl",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.other.ltl",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
