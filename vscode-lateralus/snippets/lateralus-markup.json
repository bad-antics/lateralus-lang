{
  "LTLM Front Matter": {
    "prefix": "fm",
    "body": [
      "---",
      "title: \"${1:Title}\"",
      "author: \"${2:Author}\"",
      "date: \"${3:2026-01-01}\"",
      "category: \"${4:language}\"",
      "---",
      "",
      "${0}"
    ],
    "description": "LTLM front matter block"
  },
  "LTLM Heading 1": {
    "prefix": "h1",
    "body": ["# ${0}"],
    "description": "H1 heading"
  },
  "LTLM Heading 2": {
    "prefix": "h2",
    "body": ["## ${0}"],
    "description": "H2 heading"
  },
  "LTLM Heading 3": {
    "prefix": "h3",
    "body": ["### ${0}"],
    "description": "H3 heading"
  },
  "LTLM Lateralus Code Block": {
    "prefix": "ltl",
    "body": [
      "```lateralus",
      "${0}",
      "```"
    ],
    "description": "Fenced Lateralus code block"
  },
  "LTLM Assembly Code Block": {
    "prefix": "asm",
    "body": [
      "```lateralus-asm",
      "${0}",
      "```"
    ],
    "description": "Fenced Lateralus Assembly code block"
  },
  "LTLM Note Block": {
    "prefix": "note",
    "body": [
      "::: note",
      "${0}",
      ":::"
    ],
    "description": "LTLM note block"
  },
  "LTLM Warning Block": {
    "prefix": "warn",
    "body": [
      "::: warning",
      "${0}",
      ":::"
    ],
    "description": "LTLM warning block"
  },
  "LTLM Example Block": {
    "prefix": "example",
    "body": [
      "::: example",
      "${0}",
      ":::"
    ],
    "description": "LTLM example block"
  },
  "LTLM Output Block": {
    "prefix": "output",
    "body": [
      "::: output",
      "${0}",
      ":::"
    ],
    "description": "LTLM output block"
  },
  "LTLM Math Block": {
    "prefix": "math",
    "body": [
      "::: math",
      "${0}",
      ":::"
    ],
    "description": "LTLM math block"
  },
  "LTLM Bold": {
    "prefix": "bold",
    "body": ["**${1:text}**${0}"],
    "description": "Bold text"
  },
  "LTLM Italic": {
    "prefix": "ital",
    "body": ["*${1:text}*${0}"],
    "description": "Italic text"
  },
  "LTLM Inline Code": {
    "prefix": "ic",
    "body": ["`${1:code}`${0}"],
    "description": "Inline code"
  },
  "LTLM Link": {
    "prefix": "link",
    "body": ["[${1:label}](${2:url})${0}"],
    "description": "Hyperlink"
  },
  "LTLM Horizontal Rule": {
    "prefix": "hr",
    "body": ["---"],
    "description": "Horizontal rule"
  }
}
