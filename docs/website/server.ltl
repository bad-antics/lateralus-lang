// -- HTTP → HTTPS Redirect Server ------------------------------------------

async fn redirect_handler(req: Request) -> Response {
    let host = req.headers
        |> get("host")
        |> unwrap_or("lateralus.dev")
        |> split(":")
        |> first()

    Response {
        status: 301,
        headers: {
            "Location": "https://{host}{req.path}",
            "Cache-Control": "public, max-age=86400",
            "Strict-Transport-Security": "max-age=63072000; includeSubDomains; preload",
        },
        body: "",
    }
}

// -- Route: POST /api/run — Sandboxed Code Execution ------------------------

const MAX_OUTPUT_LINES = 200
const MAX_OUTPUT_BYTES = 16384
const MAX_EXEC_STEPS  = 50000

async fn handle_run(state: AppState, req: Request) -> (Response, AppState) {
    let ip = req.headers |> get("x-forwarded-for") |> unwrap_or("unknown")
    let state = state |> check_rate("run", ip, 30, 60)

    if state.rate_blocked {
        let resp = json_error("Rate limit exceeded (30/min)", 429)
        return (resp, state)
    }

    let body = req.body |> json.parse()
    let code = body |> get("code") |> unwrap_or("")

    if code |> len() == 0 {
        let resp = json_error("Missing 'code' field", 400)
        return (resp, state)
    }

    if code |> len() > 32768 {
        let resp = json_error("Code too large (max 32KB)", 413)
        return (resp, state)
    }

    let start = time.now()

    // Lex → Parse → Evaluate with sandboxed limits
    let result = try {
        let tokens = lateralus.lex(code)
        let ast    = lateralus.parse(tokens)
        lateralus.eval(ast, {
            max_steps: MAX_EXEC_STEPS,
            max_output_lines: MAX_OUTPUT_LINES,
            max_output_bytes: MAX_OUTPUT_BYTES,
            sandbox: true,  // disables fs, net, process
        })
    } recover err {
        {
            success: false,
            error: { type: "LateralusError", message: err.message },
            output: [],
        }
    }

    let elapsed = time.now() - start

    let resp = Response {
        status: 200,
        headers: {
            "Content-Type": "application/json",
            "Cache-Control": "no-store",
            "Access-Control-Allow-Origin": "https://lateralus.dev",
        },
        body: json.stringify({
            success: result.success |> unwrap_or(true),
            output: result.output |> unwrap_or([]),
            error: result.error |> unwrap_or(None),
            stats: {
                elapsed_ms: elapsed,
                steps: result.steps |> unwrap_or(0),
                lines: result.output |> unwrap_or([]) |> len(),
            },
        }),
    } |> apply_headers(SECURITY_HEADERS)

    return (resp, state)
}

// -- Main Request Handler ---------------------------------------------------

async fn handle(state: AppState, req: Request) -> (Response, AppState) {
    let rid = request_id()

    // -- www → apex redirect --
    let host = req.headers |> get("host") |> unwrap_or("")
    if host |> starts_with("www.") {
        let apex = host |> slice(4)
        let resp = Response {
            status: 301,
            headers: { "Location": "https://{apex}{req.path}" },
            body: "",
        }
        return (resp, state)
    }

    // -- Method allowlist --
    let allowed_methods = ["GET", "HEAD", "POST", "OPTIONS"]
    if not (allowed_methods |> contains(req.method)) {
        let resp = Response { status: 405, headers: { "Allow": "GET, HEAD, POST, OPTIONS" }, body: "" }
            |> apply_headers(SECURITY_HEADERS)
        log_request(req, 405, rid)
        return (resp, state)
    }

    // -- CORS preflight --
    if req.method == "OPTIONS" {
        let resp = Response {
            status: 204,
            headers: {
                "Access-Control-Allow-Methods": "POST",
                "Access-Control-Allow-Headers": "Content-Type",
                "Access-Control-Max-Age":       "86400",
            },
            body: "",
        }
            |> apply_headers(SECURITY_HEADERS)
        return (resp, state)
    }

    // -- Request size limits --
    let content_length = req.headers
        |> get("content-length")
        |> map(parse_int_or(_, 0))
        |> unwrap_or(0)
    if content_length > 65536 {
        let resp = Response { status: 413, headers: {}, body: "Request too large" }
            |> apply_headers(SECURITY_HEADERS)
        log_request(req, 413, rid)
        return (resp, state)
    }

    // -- API routes --
    if req.path == "/api/share" and req.method == "POST" {
        let (resp, state) = await handle_share(state, req)
        log_request(req, resp.status, rid)
        return (resp, state)
    }

    if req.path == "/api/version" and req.method == "GET" {
        let data = {
            "language": "Lateralus",
            "version": "3.0.1",
            "compiler": { "name": "ltlc", "targets": ["python", "c99", "freestanding-c"] },
            "install": "pip install lateralus-lang",
            "release_date": "2026-03-28",
        }
        let resp = Response {
            status: 200,
            headers: {
                "Content-Type": "application/json",
                "Cache-Control": "public, max-age=300",
                "Access-Control-Allow-Origin": "*",
            },
            body: json.stringify(data),
        } |> apply_headers(SECURITY_HEADERS)
        log_request(req, 200, rid)
        return (resp, state)
    }

    if req.path == "/api/health" and req.method == "GET" {
        let uptime_ms = time.now() - state.boot_time
        let data = {
            "status": "healthy",
            "timestamp": time.now() |> time.format_rfc3339(),
            "uptime_ms": uptime_ms,
            "version": { "language": "3.0.1", "platform": "lateralus-native" },
        }
        let resp = Response {
            status: 200,
            headers: {
                "Content-Type": "application/json",
                "Cache-Control": "no-store",
                "Access-Control-Allow-Origin": "*",
            },
            body: json.stringify(data),
        } |> apply_headers(SECURITY_HEADERS)
        log_request(req, 200, rid)
        return (resp, state)
    }

    if req.path == "/api/packages" and req.method == "GET" {
        let packages = state.package_index
        let resp = Response {
            status: 200,
            headers: {
                "Content-Type": "application/json",
                "Cache-Control": "public, max-age=3600, s-maxage=7200",
                "Access-Control-Allow-Origin": "*",
            },
            body: json.stringify(packages),
        } |> apply_headers(SECURITY_HEADERS)
        log_request(req, 200, rid)
        return (resp, state)
    }

    if req.path == "/api/run" and req.method == "POST" {
        let (resp, state) = await handle_run(state, req)
        log_request(req, resp.status, rid)
        return (resp, state)
    }

    if req.path |> starts_with("/api/") {
        let resp = json_error("Method not allowed", 405)
        log_request(req, 405, rid)
        return (resp, state)
    }

    // -- Only GET/HEAD for page routes --
    if req.method != "GET" and req.method != "HEAD" {
        let resp = Response { status: 405, headers: { "Allow": "GET, HEAD" }, body: "" }
            |> apply_headers(SECURITY_HEADERS)
        log_request(req, 405, rid)
        return (resp, state)
    }

    // -- robots.txt (served from memory) --
    if req.path == "/robots.txt" {
        let resp = Response {
            status: 200,
            headers: {
                "Content-Type": "text/plain; charset=utf-8",
                "Cache-Control": "public, max-age=3600",
            },
            body: ROBOTS_TXT,
        }
            |> apply_headers(SECURITY_HEADERS)
        log_request(req, 200, rid)
        return (resp, state)
    }

    // -- Legacy redirect: /lateralus/* → /* --
    if req.path |> starts_with("/lateralus/") {
        let new_path = req.path |> slice(10)
        let resp = Response {
            status: 301,
            headers: { "Location": new_path, "Cache-Control": "public, max-age=86400" },
            body: "",
        }
        log_request(req, 301, rid)
        return (resp, state)
    }

    // -- Protected pages: verify token --
    if is_protected(req.path) {
        let page = get_page(req.path) |> unwrap()
        let token = req |> query_param("t") |> unwrap_or("")

        if token |> len() == 0 {
            let resp = Response {
                status: 403,
                headers: { "Content-Type": "text/html; charset=utf-8" },
                body: DENIED_HTML,
            }
                |> apply_headers(PROTECTED_HEADERS)
            log_request(req, 403, rid)
            return (resp, state)
        }

        let valid = await verify_token(token, state.config.link_secret, page)
        if not valid {
            let resp = Response {
                status: 403,
                headers: { "Content-Type": "text/html; charset=utf-8" },
                body: DENIED_HTML,
            }
                |> apply_headers(PROTECTED_HEADERS)
            log_request(req, 403, rid)
            return (resp, state)
        }

        // Valid token — serve the protected file with strict headers
        match await serve_static(state.config.static_root, req.path) {
            Some(resp) => {
                let resp = resp |> apply_headers(PROTECTED_HEADERS)
                log_request(req, 200, rid)
                (resp, state)
            }
            None => {
                let resp = Response { status: 404, headers: {}, body: "Not Found" }
                    |> apply_headers(PROTECTED_HEADERS)
                log_request(req, 404, rid)
                (resp, state)
            }
        }
    } else {
        // -- Public static files --
        match await serve_static(state.config.static_root, req.path) {
            Some(resp) => {
                let resp = resp |> apply_headers(SECURITY_HEADERS)
                log_request(req, 200, rid)
                (resp, state)
            }
            None => {
                let body = "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><title>404</title></head><body><h1>404 — Not Found</h1></body></html>"
                let resp = Response {
                    status: 404,
                    headers: { "Content-Type": "text/html; charset=utf-8" },
                    body: body,
                }
                    |> apply_headers(SECURITY_HEADERS)
                log_request(req, 404, rid)
                (resp, state)
            }
        }
    }
}

// -- TLS Configuration ------------------------------------------------------

fn build_tls_config(cfg: Config) -> TlsConfig {
    TlsConfig {
        cert_file:     cfg.tls_cert,
        key_file:      cfg.tls_key,
        min_version:   TlsVersion.TLS_1_2,
        max_version:   TlsVersion.TLS_1_3,
        cipher_suites: [
            // TLS 1.3 suites (preferred)
            "TLS_AES_256_GCM_SHA384",
            "TLS_CHACHA20_POLY1305_SHA256",
            "TLS_AES_128_GCM_SHA256",
            // TLS 1.2 fallback
            "TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384",
            "TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305",
            "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256",
        ],
        curves: ["X25519", "P-256"],
        session_tickets: false,          // forward secrecy
        ocsp_stapling:   true,
    }
}

// -- Entrypoint -------------------------------------------------------------

fn main() {
    let cfg = load_config()
    log.set_level(cfg.log_level)

    let state = AppState {
        config:       cfg,
        rate_limiter: new_rate_limiter(),
    }

    let tls = build_tls_config(cfg)

    // HTTPS server (main)
    let https_server = net.https_server(cfg.host, cfg.port, tls)
    log.info("HTTPS listening on {cfg.host}:{cfg.port}")

    // HTTP → HTTPS redirect server (port 80)
    let http_server = net.http_server(cfg.host, 80)
    log.info("HTTP→HTTPS redirect on {cfg.host}:80")

    // Run both concurrently
    let https_task = spawn https_server.serve_stateful(state, handle)
    let http_task  = spawn http_server.serve(redirect_handler)

    await https_task
    await http_task
}
