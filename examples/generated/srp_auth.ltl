// ═══════════════════════════════════════════════════════════
// LATERALUS — SRP Auth
// Simplified SRP-6a Authentication Handshake in Lateralus
// ═══════════════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════
// ──────────────────────────────────────────────────────────────

// ═══════════════════════════════════════════════════════════
// IMPORTS
import math
import strings
import crypto
import io

// ═══════════════════════════════════════════════════════════
// TYPES
type Int = int
type Bool = bool
type String = str
type Key = [u8]
type Message = [u8]

// ═══════════════════════════════════════════════════════════
// STRUCTS
struct User {
  public username: String,
  public password: Key,
}

struct Server {
  public salt: Key,
  public public_key: [u8],
}

// ═══════════════════════════════════════════════════════════
// HELPER FUNCTIONS
fn generate_random_salt() -> Key {
  let mut salt = [0; 32]
  for i in 0..32 {
    salt[i] = rand_u8()
  }
  salt
}

fn compute_preimage(server_public_key, user_password) -> Key {
  let mut preimage = [0; 32]
  for (i, c) in server_public_key.iter().enumerate() {
    preimage[i] = user_password[(i + 1) % len(user_password)] ^ c;
  }
  preimage
}

fn compute_signature(message: Message, private_key) -> [u8] {
  crypto::ecdsa_sign(&message, &private_key)
}

fn verify_signature(message: Message, server_public_key, signature) -> Bool {
  crypto::ecdsa_verify(&message, &server_public_key, &signature)
}

// ═══════════════════════════════════════════════════════════
