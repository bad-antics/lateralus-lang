{
  "name": "lateralus-grammar",
  "displayName": "Lateralus",
  "description": "TextMate grammar for the Lateralus programming language. Vendored by github-linguist/linguist under vendor/grammars/lateralus-grammar to power GitHub syntax highlighting and language classification for .ltl files.",
  "version": "1.0.0",
  "publisher": "lateralus",
  "license": "MIT",
  "homepage": "https://lateralus.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bad-antics/lateralus-grammar.git"
  },
  "bugs": {
    "url": "https://github.com/bad-antics/lateralus-lang/issues"
  },
  "keywords": [
    "lateralus",
    "ltl",
    "grammar",
    "tmlanguage",
    "syntax",
    "linguist"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lateralus",
        "aliases": [
          "Lateralus",
          "lateralus",
          "lateralus-lang"
        ],
        "extensions": [
          ".ltl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lateralus",
        "scopeName": "source.ltl",
        "path": "./syntaxes/lateralus.tmLanguage.json"
      }
    ]
  }
}
