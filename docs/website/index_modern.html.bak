<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LATERALUS — Spiral Outward</title>
  <meta name="description" content="LATERALUS is a pipeline-driven programming language for scientists, engineers, and security researchers. Result/Option types, pattern matching, built-in cryptography, and scientific computing.">
  <meta name="keywords" content="programming language, pipeline, scientific computing, cryptography, pattern matching, type system, Rust-inspired, Python transpiler">
  <meta property="og:title" content="LATERALUS — Spiral Outward">
  <meta property="og:description" content="A pipeline-driven programming language built for scientists, engineers, and hackers.">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="LATERALUS — Spiral Outward">
  <meta name="twitter:description" content="Pipeline-driven. Mathematically elegant. Made for scientists and engineers.">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌀</text></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:       #0b0d14;
      --surface:  #111520;
      --card:     #161b2e;
      --border:   #1e2640;
      --primary:  #e94560;
      --gold:     #ffd700;
      --cyan:     #00d4ff;
      --green:    #39d353;
      --purple:   #9b59b6;
      --text:     #e8eaf6;
      --dim:      #6272a4;
      --mono:     'JetBrains Mono', monospace;
      --sans:     'Inter', system-ui, sans-serif;
    }
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
    }

    /* ── NAVIGATION ─────────────────────────────── */
    nav {
      position: fixed; top: 0; width: 100%; z-index: 100;
      padding: 1rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(11,13,20,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: var(--mono);
      font-size: 1.3rem; font-weight: 700;
      color: var(--primary);
      letter-spacing: .1em;
      text-decoration: none;
    }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      color: var(--dim); font-size: .9rem; text-decoration: none;
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--text); }
    .nav-cta {
      background: var(--primary); color: #fff;
      padding: .45rem 1.1rem; border-radius: 6px;
      font-size: .85rem; font-weight: 600; text-decoration: none;
      transition: opacity .2s;
    }
    .nav-cta:hover { opacity: .85; }

    /* ── HERO ─────────────────────────────────────── */
    #hero {
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      flex-direction: column; text-align: center;
      padding: 6rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }
    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(233,69,96,.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(233,69,96,.06) 1px, transparent 1px);
      background-size: 60px 60px;
      animation: gridDrift 40s linear infinite;
    }
    @keyframes gridDrift {
      from { transform: translateY(0); }
      to   { transform: translateY(60px); }
    }
    .hero-glow {
      position: absolute; width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(233,69,96,.18) 0%, transparent 70%);
      border-radius: 50%; pointer-events: none;
      top: 50%; left: 50%; transform: translate(-50%,-50%);
      animation: pulse 6s ease-in-out infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: .6; transform: translate(-50%,-50%) scale(1); }
      50%      { opacity: 1;  transform: translate(-50%,-50%) scale(1.15); }
    }
    .hero-version {
      font-family: var(--mono); font-size: .8rem;
      background: rgba(233,69,96,.15);
      border: 1px solid rgba(233,69,96,.3);
      color: var(--primary); padding: .3rem .8rem;
      border-radius: 20px; margin-bottom: 2rem;
      position: relative; z-index: 1;
    }
    h1.hero-title {
      font-size: clamp(3rem, 10vw, 7rem);
      font-weight: 900; letter-spacing: -.03em;
      line-height: 1;
      background: linear-gradient(135deg, #fff 30%, var(--primary) 70%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      position: relative; z-index: 1;
      margin-bottom: 1.5rem;
    }
    .hero-sub {
      font-size: clamp(1rem, 2.5vw, 1.35rem);
      color: var(--dim); max-width: 600px;
      line-height: 1.7; position: relative; z-index: 1;
      margin-bottom: 2.5rem;
    }
    .hero-buttons {
      display: flex; gap: 1rem; flex-wrap: wrap;
      justify-content: center; position: relative; z-index: 1;
      margin-bottom: 4rem;
    }
    .btn-primary {
      background: var(--primary); color: #fff;
      padding: .85rem 2rem; border-radius: 8px;
      font-size: 1rem; font-weight: 600; text-decoration: none;
      transition: transform .2s, box-shadow .2s;
      box-shadow: 0 0 30px rgba(233,69,96,.3);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 50px rgba(233,69,96,.5); }
    .btn-outline {
      border: 1px solid var(--border); color: var(--text);
      padding: .85rem 2rem; border-radius: 8px;
      font-size: 1rem; font-weight: 600; text-decoration: none;
      transition: border-color .2s, background .2s;
    }
    .btn-outline:hover { border-color: var(--dim); background: var(--card); }

    /* ── HERO CODE ───────────────────────────────── */
    .hero-code {
      position: relative; z-index: 1;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px; overflow: hidden;
      max-width: 680px; width: 100%;
      text-align: left;
      box-shadow: 0 20px 80px rgba(0,0,0,.6);
    }
    .code-titlebar {
      display: flex; align-items: center; gap: .5rem;
      padding: .75rem 1rem;
      background: rgba(255,255,255,.03);
      border-bottom: 1px solid var(--border);
    }
    .dot { width: 12px; height: 12px; border-radius: 50%; }
    .dot-r { background: #ff5f57; }
    .dot-y { background: #febc2e; }
    .dot-g { background: #28c840; }
    .code-filename {
      font-family: var(--mono); font-size: .8rem;
      color: var(--dim); margin-left: .5rem;
    }
    .code-body {
      padding: 1.5rem; font-family: var(--mono);
      font-size: .88rem; line-height: 1.8;
      overflow-x: auto;
    }
    .kw  { color: #c792ea; }
    .fn  { color: #82aaff; }
    .str { color: #c3e88d; }
    .num { color: #f78c6c; }
    .cmt { color: #546e7a; font-style: italic; }
    .op  { color: var(--primary); }
    .typ { color: var(--gold); }

    /* ── FEATURES GRID ───────────────────────────── */
    section { padding: 6rem 2rem; }
    .section-label {
      font-family: var(--mono); font-size: .75rem;
      letter-spacing: .2em; text-transform: uppercase;
      color: var(--primary); margin-bottom: .75rem;
    }
    .section-title {
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 800; line-height: 1.15;
      margin-bottom: 1rem;
    }
    .section-sub {
      color: var(--dim); font-size: 1.05rem;
      max-width: 560px; line-height: 1.7;
      margin-bottom: 3rem;
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.5rem;
      max-width: 1100px; margin: 0 auto;
    }
    .feature-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px; padding: 1.75rem;
      transition: transform .2s, border-color .2s, box-shadow .2s;
    }
    .feature-card:hover {
      transform: translateY(-4px);
      border-color: rgba(233,69,96,.4);
      box-shadow: 0 8px 40px rgba(233,69,96,.1);
    }
    .feature-icon {
      font-size: 2rem; margin-bottom: 1rem; display: block;
    }
    .feature-title {
      font-weight: 700; font-size: 1.05rem; margin-bottom: .5rem;
    }
    .feature-desc { color: var(--dim); font-size: .9rem; line-height: 1.6; }

    /* ── PIPELINE DEMO ───────────────────────────── */
    #pipeline { background: var(--surface); text-align: center; }
    .pipeline-flow {
      display: flex; align-items: center; justify-content: center;
      flex-wrap: wrap; gap: 0; max-width: 900px; margin: 0 auto 3rem;
    }
    .pipe-step {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px; padding: 1rem 1.5rem;
      font-family: var(--mono); font-size: .85rem;
      transition: border-color .3s;
      cursor: default;
    }
    .pipe-step:hover { border-color: var(--primary); }
    .pipe-arrow {
      color: var(--primary); font-size: 1.4rem;
      margin: 0 .5rem; font-family: var(--mono);
    }
    .pipe-label { color: var(--dim); font-size: .75rem; margin-top: .3rem; }

    /* ── ECOSYSTEM TABLE ─────────────────────────── */
    #ecosystem { text-align: center; }
    .eco-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem; max-width: 1000px; margin: 0 auto;
    }
    .eco-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.25rem;
      text-align: left; transition: border-color .2s;
    }
    .eco-card:hover { border-color: var(--cyan); }
    .eco-tag {
      font-family: var(--mono); font-size: .7rem;
      color: var(--cyan); letter-spacing: .1em;
      text-transform: uppercase; margin-bottom: .4rem;
    }
    .eco-name { font-weight: 700; font-size: .95rem; margin-bottom: .3rem; }
    .eco-desc { color: var(--dim); font-size: .82rem; line-height: 1.5; }

    /* ── STATS BAR ───────────────────────────────── */
    #stats {
      background: linear-gradient(135deg, var(--surface), var(--card));
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .stats-row {
      display: flex; justify-content: space-around;
      flex-wrap: wrap; gap: 2rem;
      max-width: 800px; margin: 0 auto;
      padding: 3rem 2rem; text-align: center;
    }
    .stat-num {
      font-size: 3rem; font-weight: 900;
      background: linear-gradient(135deg, var(--gold), var(--primary));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      font-family: var(--mono);
    }
    .stat-label { color: var(--dim); font-size: .85rem; margin-top: .25rem; }

    /* ── CODE TABS ───────────────────────────────── */
    #examples { text-align: center; background: var(--surface); }
    .tabs {
      display: flex; gap: .5rem; justify-content: center;
      flex-wrap: wrap; margin-bottom: 2rem;
    }
    .tab-btn {
      background: var(--card); border: 1px solid var(--border);
      color: var(--dim); padding: .5rem 1.2rem;
      border-radius: 6px; font-family: var(--mono); font-size: .82rem;
      cursor: pointer; transition: all .2s;
    }
    .tab-btn.active, .tab-btn:hover {
      background: var(--primary); border-color: var(--primary);
      color: #fff;
    }
    .tab-panel { display: none; text-align: left; }
    .tab-panel.active { display: block; }
    .demo-block {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 12px; overflow: hidden;
      max-width: 720px; margin: 0 auto;
    }

    /* ── TIMELINE ────────────────────────────────── */
    #roadmap { text-align: center; }
    .timeline {
      max-width: 600px; margin: 0 auto;
      position: relative;
    }
    .timeline::before {
      content: ''; position: absolute;
      left: 50%; transform: translateX(-50%);
      width: 2px; height: 100%;
      background: linear-gradient(to bottom, var(--primary), transparent);
    }
    .tl-item {
      display: flex; gap: 2rem; align-items: flex-start;
      margin-bottom: 2.5rem; position: relative;
    }
    .tl-item:nth-child(even) { flex-direction: row-reverse; }
    .tl-dot {
      width: 14px; height: 14px; border-radius: 50%;
      background: var(--primary); flex-shrink: 0;
      margin-top: .3rem; position: relative; z-index: 1;
      box-shadow: 0 0 15px var(--primary);
    }
    .tl-dot.future { background: var(--border); box-shadow: none; }
    .tl-content {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; padding: 1rem 1.25rem;
      flex: 1; text-align: left;
    }
    .tl-version { font-family: var(--mono); color: var(--gold); font-size: .85rem; }
    .tl-desc { color: var(--dim); font-size: .88rem; margin-top: .3rem; line-height: 1.5; }

    /* ── QUOTE ───────────────────────────────────── */
    #quote {
      text-align: center;
      background: radial-gradient(ellipse at center, rgba(233,69,96,.08) 0%, transparent 70%);
    }
    blockquote.hero-quote {
      max-width: 700px; margin: 0 auto;
      font-size: clamp(1.2rem, 2.5vw, 1.8rem);
      font-weight: 300; line-height: 1.7;
      color: var(--text); font-style: italic;
    }
    blockquote.hero-quote em { color: var(--primary); font-style: normal; }
    .quote-attr {
      margin-top: 1.5rem; color: var(--dim);
      font-family: var(--mono); font-size: .85rem;
    }

    /* ── INSTALL ─────────────────────────────────── */
    #install { text-align: center; }
    .install-cmd {
      display: inline-flex; align-items: center; gap: 1rem;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; padding: 1rem 1.5rem;
      font-family: var(--mono); font-size: 1rem;
      margin-bottom: 1rem;
    }
    .install-cmd .prompt { color: var(--primary); }
    .copy-btn {
      background: var(--surface); border: 1px solid var(--border);
      color: var(--dim); padding: .3rem .6rem;
      border-radius: 5px; cursor: pointer; font-size: .75rem;
      transition: all .2s;
    }
    .copy-btn:hover { border-color: var(--cyan); color: var(--cyan); }

    /* ── FOOTER ──────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding: 3rem 2rem;
      display: flex; justify-content: space-between;
      align-items: center; flex-wrap: wrap; gap: 2rem;
      max-width: 1100px; margin: 0 auto;
    }
    .footer-logo {
      font-family: var(--mono); font-size: 1.1rem;
      color: var(--primary); font-weight: 700;
    }
    .footer-links { display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .footer-links a { color: var(--dim); text-decoration: none; font-size: .9rem; transition: color .2s; }
    .footer-links a:hover { color: var(--text); }
    .footer-copy { color: var(--dim); font-size: .82rem; }

    /* ── SCROLLBAR ───────────────────────────────── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

    /* ── RESPONSIVE ──────────────────────────────── */
    @media(max-width:768px) {
      .nav-links { display: none; }
      .timeline::before { left: 7px; }
      .tl-item, .tl-item:nth-child(even) { flex-direction: column; }
      .audience-grid { grid-template-columns: 1fr; }
    }

    /* ── AUDIENCE SECTION ────────────────────────── */
    .audience-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2rem; max-width: 1100px; margin: 0 auto;
    }
    .audience-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 14px; padding: 2.5rem 2rem;
      transition: transform .2s, border-color .3s;
      position: relative; overflow: hidden;
    }
    .audience-card:hover { transform: translateY(-3px); }
    .audience-card::before {
      content: ''; position: absolute; top: 0; left: 0;
      width: 100%; height: 3px;
    }
    .audience-card.sci::before { background: linear-gradient(90deg, var(--cyan), var(--purple)); }
    .audience-card.sec::before { background: linear-gradient(90deg, var(--primary), #f78c6c); }
    .audience-card.eng::before { background: linear-gradient(90deg, var(--green), var(--cyan)); }
    .audience-card:hover.sci { border-color: var(--cyan); }
    .audience-card:hover.sec { border-color: var(--primary); }
    .audience-card:hover.eng { border-color: var(--green); }
    .audience-icon { font-size: 2.5rem; margin-bottom: 1.2rem; display: block; }
    .audience-title { font-size: 1.3rem; font-weight: 800; margin-bottom: .6rem; }
    .audience-desc { color: var(--dim); font-size: .92rem; line-height: 1.7; margin-bottom: 1.2rem; }
    .audience-features {
      list-style: none; padding: 0;
      font-family: var(--mono); font-size: .82rem; color: var(--text);
    }
    .audience-features li { padding: .3rem 0; }
    .audience-features li::before { content: '→ '; color: var(--primary); }

    /* ── BLOG PREVIEW ────────────────────────────── */
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem; max-width: 1100px; margin: 0 auto;
    }
    .blog-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 12px; padding: 1.5rem;
      text-align: left; transition: border-color .2s;
    }
    .blog-card:hover { border-color: var(--primary); }
    .blog-date { font-family: var(--mono); font-size: .72rem; color: var(--primary); margin-bottom: .5rem; }
    .blog-title { font-weight: 700; font-size: 1.05rem; margin-bottom: .4rem; }
    .blog-excerpt { color: var(--dim); font-size: .88rem; line-height: 1.6; }

    /* ── TIMELINE TAG STYLES ─────────────────────── */
    .tl-tag {
      display: inline-block; font-family: var(--mono); font-size: .6rem;
      padding: .15rem .5rem; border-radius: 8px; margin-left: .4rem;
      vertical-align: middle;
    }
    .tl-tag.done { background: rgba(57,211,83,.15); color: var(--green); }
    .tl-tag.now  { background: rgba(0,212,255,.15); color: var(--cyan); }
    .tl-dot.complete { background: var(--green); box-shadow: 0 0 15px var(--green); }
    .tl-dot.current  { background: var(--cyan); box-shadow: 0 0 20px var(--cyan); }
  </style>
</head>
<body>

<!-- NAVIGATION -->
<nav>
  <a class="nav-logo" href="#">LATERALUS</a>
  <ul class="nav-links">
    <li><a href="#features">Features</a></li>
    <li><a href="#audiences">Who It's For</a></li>
    <li><a href="#examples">Examples</a></li>
    <li><a href="#ecosystem">Ecosystem</a></li>
    <li><a href="#blog">Blog</a></li>
    <li><a href="#roadmap">Roadmap</a></li>
    <li><a href="retro/index.html">Retro Site</a></li>
  </ul>
  <a class="nav-cta" href="#install">Get Started</a>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>
  <div class="hero-version">v1.9.0 — FFI &amp; Ecosystem</div>
  <h1 class="hero-title">LATERALUS</h1>
  <p class="hero-sub">
    A programming language built for clarity, power, and discovery.
    Pipeline-driven. Type-safe. Mathematically elegant.
    Made for scientists, engineers, and security researchers.
  </p>
  <div style="display:flex;gap:.5rem;flex-wrap:wrap;justify-content:center;margin-bottom:2rem;position:relative;z-index:1;">
    <span style="font-family:var(--mono);font-size:.72rem;background:var(--card);border:1px solid var(--border);color:var(--dim);padding:.25rem .7rem;border-radius:12px;"><span style="color:var(--cyan);">ffi</span> C interop</span>
    <span style="font-family:var(--mono);font-size:.72rem;background:var(--card);border:1px solid var(--border);color:var(--dim);padding:.25rem .7rem;border-radius:12px;"><span style="color:var(--cyan);">wasm</span> target</span>
    <span style="font-family:var(--mono);font-size:.72rem;background:var(--card);border:1px solid var(--border);color:var(--dim);padding:.25rem .7rem;border-radius:12px;"><span style="color:var(--cyan);">js</span> transpile</span>
    <span style="font-family:var(--mono);font-size:.72rem;background:var(--card);border:1px solid var(--border);color:var(--dim);padding:.25rem .7rem;border-radius:12px;"><span style="color:var(--cyan);">jupyter</span> kernel</span>
    <span style="font-family:var(--mono);font-size:.72rem;background:var(--card);border:1px solid var(--border);color:var(--dim);padding:.25rem .7rem;border-radius:12px;"><span style="color:var(--cyan);">|&gt;</span> pipelines</span>
    <span style="font-family:var(--mono);font-size:.72rem;background:var(--card);border:1px solid var(--border);color:var(--dim);padding:.25rem .7rem;border-radius:12px;"><span style="color:var(--cyan);">Result</span>::Ok / Err</span>
    <span style="font-family:var(--mono);font-size:.72rem;background:var(--card);border:1px solid var(--border);color:var(--dim);padding:.25rem .7rem;border-radius:12px;"><span style="color:var(--cyan);">macro!</span> metaprogramming</span>
  </div>
  <div class="hero-buttons">
    <a class="btn-primary" href="#install">Install Now</a>
    <a class="btn-outline" href="#examples">See Examples</a>
  </div>
  <div class="hero-code">
    <div class="code-titlebar">
      <div class="dot dot-r"></div>
      <div class="dot dot-y"></div>
      <div class="dot dot-g"></div>
      <span class="code-filename">v19_showcase.ltl</span>
    </div>
    <div class="code-body">
<span class="cmt">// v1.9 — FFI, WASM, JavaScript, Jupyter</span>
<span class="kw">import</span> math

<span class="kw">struct</span> <span class="typ">Vector2D</span> { x: <span class="typ">float</span>, y: <span class="typ">float</span> }

<span class="kw">fn</span> <span class="fn">vec_length</span>(v: <span class="typ">Vector2D</span>) <span class="op">-&gt;</span> <span class="typ">float</span> {
  <span class="kw">return</span> <span class="fn">sqrt</span>(v.x * v.x + v.y * v.y)
}

<span class="cmt">// Multi-target: Python, C, JS, or WASM</span>
<span class="kw">let</span> points = <span class="fn">generate_points</span>(<span class="num">100</span>)
<span class="kw">let</span> result = points
  <span class="op">|&gt;</span> <span class="fn">filter</span>(<span class="kw">fn</span>(p) { <span class="fn">vec_length</span>(p) &lt; <span class="num">10.0</span> })
  <span class="op">|&gt;</span> <span class="fn">map</span>(<span class="kw">fn</span>(p) { <span class="fn">vec_length</span>(p) })
  <span class="op">|&gt;</span> <span class="fn">mean</span>()
    </div>
  </div>
</section>

