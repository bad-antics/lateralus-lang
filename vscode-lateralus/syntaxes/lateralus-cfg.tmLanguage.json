{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lateralus Config",
  "scopeName": "source.ltlcfg",
  "fileTypes": ["ltlcfg"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#include-directive" },
    { "include": "#section-header" },
    { "include": "#computed-field" },
    { "include": "#typed-field" },
    { "include": "#untyped-field" },
    { "include": "#env-variable" },
    { "include": "#strings" },
    { "include": "#multiline-string" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#list" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "comments": {
      "name": "comment.line.hash.ltlcfg",
      "match": "#.*$"
    },

    "include-directive": {
      "name": "meta.include.ltlcfg",
      "match": "^\\s*(!include)\\s+(\\S+)",
      "captures": {
        "1": { "name": "keyword.control.include.ltlcfg" },
        "2": { "name": "string.unquoted.path.ltlcfg" }
      }
    },

    "section-header": {
      "name": "meta.section.ltlcfg",
      "match": "^\\s*(\\[)([A-Za-z_][A-Za-z0-9_.]*)(\\])",
      "captures": {
        "1": { "name": "punctuation.definition.section.begin.ltlcfg" },
        "2": { "name": "entity.name.section.ltlcfg" },
        "3": { "name": "punctuation.definition.section.end.ltlcfg" }
      }
    },

    "computed-field": {
      "name": "meta.field.computed.ltlcfg",
      "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*=\\s*(.*?)\\s*(?=#|$)",
      "captures": {
        "1": { "name": "variable.other.field.ltlcfg" },
        "2": { "name": "punctuation.separator.type.ltlcfg" },
        "3": { "name": "meta.expression.computed.ltlcfg" }
      }
    },

    "typed-field": {
      "name": "meta.field.typed.ltlcfg",
      "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*(str|int|float|bool|list(?:\\[[^\\]]*\\])?|dict|any)\\s*(=)\\s*",
      "captures": {
        "1": { "name": "variable.other.field.ltlcfg" },
        "2": { "name": "punctuation.separator.type.ltlcfg" },
        "3": { "name": "support.type.ltlcfg" },
        "4": { "name": "keyword.operator.assignment.ltlcfg" }
      }
    },

    "untyped-field": {
      "name": "meta.field.untyped.ltlcfg",
      "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(=)\\s*",
      "captures": {
        "1": { "name": "variable.other.field.ltlcfg" },
        "2": { "name": "keyword.operator.assignment.ltlcfg" }
      }
    },

    "env-variable": {
      "name": "variable.other.env.ltlcfg",
      "match": "\\$\\{[A-Za-z_][A-Za-z0-9_]*\\}",
      "captures": {
        "0": { "name": "variable.other.env.ltlcfg" }
      }
    },

    "strings": {
      "name": "string.quoted.double.ltlcfg",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.ltlcfg" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.ltlcfg" } },
      "patterns": [
        {
          "name": "constant.character.escape.ltlcfg",
          "match": "\\\\[ntr\\\\\"0]"
        },
        { "include": "#env-variable" }
      ]
    },

    "multiline-string": {
      "name": "string.quoted.triple.ltlcfg",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.ltlcfg" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.ltlcfg" } }
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ltlcfg",
          "match": "\\b-?[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.ltlcfg",
          "match": "\\b-?[0-9]+\\b"
        }
      ]
    },

    "booleans": {
      "name": "constant.language.boolean.ltlcfg",
      "match": "\\b(true|false|yes|no|on|off)\\b"
    },

    "list": {
      "name": "meta.structure.list.ltlcfg",
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": { "0": { "name": "punctuation.definition.list.begin.ltlcfg" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.list.end.ltlcfg" } },
      "patterns": [
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#comments" },
        { "include": "#env-variable" },
        {
          "name": "punctuation.separator.comma.ltlcfg",
          "match": ","
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.ltlcfg",
          "match": ","
        },
        {
          "name": "punctuation.separator.dot.ltlcfg",
          "match": "\\."
        }
      ]
    }
  }
}
