# ===============================================================
# Optional: Caddy reverse proxy config
# If you prefer Caddy handling TLS (auto Let's Encrypt),
# run server.ltl without TLS and proxy through Caddy.
# ===============================================================

lateralus.dev, www.lateralus.dev {
    # www → apex
    @www host www.lateralus.dev
    redir @www https://lateralus.dev{uri} permanent

    # Proxy to the Lateralus server
    reverse_proxy localhost:8443 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Additional hardening at edge
    header {
        -Server
        -X-Powered-By
    }

    # Rate limiting at edge (Caddy rate-limit plugin)
    # rate_limit {remote.ip} 60r/m

    log {
        output file /var/log/caddy/lateralus.dev.log
        format json
    }
}
