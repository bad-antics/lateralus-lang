# ═══════════════════════════════════════════════════════════════
# Lateralus Language — GitHub Linguist Configuration
# ═══════════════════════════════════════════════════════════════
# Map Lateralus files to similar languages for GitHub syntax
# highlighting until Lateralus is added to Linguist natively.
# ═══════════════════════════════════════════════════════════════

# ── Lateralus source files (the actual language) ──────────────
# Lateralus Script → Rust (closest syntax: fn, let, struct, impl, |>, match)
*.ltl linguist-language=Rust

# Lateralus Assembly → NASM (assembly with labels, directives, opcodes)
*.ltasm linguist-language=NASM

# Lateralus Markup → HTML (embedded markup with code blocks)
*.ltlm linguist-language=HTML
*.ltlml linguist-language=HTML

# Lateralus Config → TOML (key-value config files)
*.ltlcfg linguist-language=TOML

# Lateralus Notebook → Markdown
*.ltlnb linguist-language=Markdown

# ── Toolchain (Python implementation — not the language itself) ──
# Mark as vendored so Python doesn't dominate the repo language stats.
# The repo IS a Lateralus project; Python is just the implementation detail.
lateralus_lang/*.py linguist-vendored
lateralus_lang/**/*.py linguist-vendored
tests/*.py linguist-vendored
tests/**/*.py linguist-vendored
scripts/*.py linguist-vendored
docs/*.py linguist-vendored
lateralus-os/**/*.py linguist-vendored
setup.py linguist-vendored
conftest.py linguist-vendored

# ── VS Code extension (JavaScript implementation) ──────────────
vscode-lateralus/*.js linguist-vendored

# ── Binary / generated formats ─────────────────────────────────
*.ltbc linguist-generated
*.ltlc linguist-generated
*.vsix linguist-generated
dist/** linguist-generated
