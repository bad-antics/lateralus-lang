fn dnsEncodeQuery(q: Query) -> bytes {
    // Encode query packet into bytes using some encoding scheme (e.g., DNS)
    // NOTE: This is just an example, and actual implementation depends on the protocol
    let b = [0x00; 12] // magic number and length of the response
    return b;
}

fn parseResponse(response: Response) -> list[struct {
    name: str,
    ip: str,
}] {
    // Parse DNS response into a list of answers
    todo!();
}

fn followCNAMEChain(answers: list[struct { name: str, ip: str }], cname: str) -> list[struct { name: str, ip: str }] {
    // Follow CNAME chain by recursively looking up the next domain
    // NOTE: This is just an example, and actual implementation depends on the protocol
    if cname == "" {
        return answers
    }
    for answer in answers {
        if answer.name.endswith(cname) {
            return followCNAMEChain(parseResponse({
                q: "CNAME".toBytes() + answer.ip.toBytes(),
                ttl: answer.ttl,
            }), answer.ip.slice(answer.ip.index(".).")
        )
    }
    return answers;
}

// ─── Section 4. Main Function ────────────────────────────────────────
async fn main(query: Query) -> list[struct { name: str, ip: str }] {
    // Recursive DNS resolver
    let response = dnsEncodeQuery(query);
    let answers = parseResponse({
        q: response.toBytes(), // TODO: implement this
        ttl: query.ttl,
    });
    return followCNAMEChain(answers, "")
}

