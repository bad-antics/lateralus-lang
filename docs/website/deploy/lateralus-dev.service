[Unit]
Description=lateralus.dev — Lateralus web server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=lateralus
Group=lateralus
WorkingDirectory=/srv/lateralus.dev
EnvironmentFile=/srv/lateralus.dev/.env

ExecStart=/srv/lateralus.dev/lateralus-server
Restart=on-failure
RestartSec=5

# -- Hardening --
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictAddressFamilies=AF_INET AF_INET6
RestrictNamespaces=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallArchitectures=native
SystemCallFilter=@system-service
ReadWritePaths=/srv/lateralus.dev/logs
ReadOnlyPaths=/srv/lateralus.dev/public /etc/letsencrypt

# Allow binding to privileged ports (80, 443)
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
