        5 => [{ from: 1, to: 4 }, { from: 12, to: 13 }],
        6 => [{ from: 2, to: 7 }, { from: 14, to: 15 }],
        7 => [{ from: 2, to: 6 }, { from: 16, to: 17 }],
        8 => [{ from: 3, to: 9 }, { from: 18, to: 19 }],
        9
