{
  "LTasm Section": {
    "prefix": ".section",
    "body": [".section ${1|code,data,bss|}"],
    "description": "Section directive"
  },
  "LTasm Global": {
    "prefix": ".global",
    "body": [".global ${1:_start}"],
    "description": "Global symbol directive"
  },
  "LTasm Entry Point": {
    "prefix": "entry",
    "body": [
      ".section code",
      ".global _start",
      "",
      "_start:",
      "\t${0}",
      "\tPUSH_IMM  0",
      "\tHALT"
    ],
    "description": "Full entry point boilerplate"
  },
  "LTasm Push String and Print": {
    "prefix": "prints",
    "body": [
      "PUSH_STR  \"${1:Hello}\"",
      "PRINTLN"
    ],
    "description": "Push string and println"
  },
  "LTasm Subroutine": {
    "prefix": "sub",
    "body": [
      "${1:name}:",
      "\t${0}",
      "\tRET"
    ],
    "description": "Subroutine with RET"
  },
  "LTasm Call Subroutine": {
    "prefix": "call",
    "body": ["CALL  ${1:.label}"],
    "description": "Call a subroutine"
  },
  "LTasm Conditional Jump": {
    "prefix": "jt",
    "body": [
      "JT    ${1:.label}",
      "JF    ${2:.label}"
    ],
    "description": "Conditional jump pair"
  },
  "LTasm Move Immediate": {
    "prefix": "movimm",
    "body": ["MOV_IMM  r${1:0}, ${2:0}"],
    "description": "Load immediate into register"
  },
  "LTasm Try/Recover": {
    "prefix": "try",
    "body": [
      "TRY_BEGIN  ${1:.recover}",
      "\t${0}",
      "TRY_END",
      "JMP       ${2:.done}",
      "${1:recover}:",
      "\t; handle error",
      "RETHROW",
      "${2:done}:"
    ],
    "description": "Try/recover error frame"
  },
  "LTasm Spawn Coroutine": {
    "prefix": "spawn",
    "body": [
      "PUSH_IMM  ${1:0}",
      "SPAWN",
      "POP_REG   r${2:0}",
      "AWAIT_OP"
    ],
    "description": "Spawn and await a coroutine"
  }
}
