// Rosetta Code · FizzBuzz · Lateralus
// Print numbers 1..n; multiples of 3 -> "Fizz", 5 -> "Buzz", both -> "FizzBuzz".

fn fizzbuzz(n: int) {
    let i = 1
    while i <= n {
        if i % 15 == 0 {
            print("FizzBuzz")
        } else if i % 3 == 0 {
            print("Fizz")
        } else if i % 5 == 0 {
            print("Buzz")
        } else {
            print(str(i))
        }
        i = i + 1
    }
}

fn main() {
    fizzbuzz(15)
}

main()
