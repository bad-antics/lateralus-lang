fn greet(name: str) -> str {
    return "Hello, " + name + "!"
}

fn main() {
    println(greet("world"))

    // Pipeline demo
    let squares = [1, 2, 3, 4, 5]
        |> filter(fn(x) { x % 2 == 1 })
        |> map(fn(x) { x * x })

    for n in squares {
        println(n)
    }
}

main()
