# ===============================================================
# LATERALUS Documentation — Apache Configuration
# ===============================================================
# Serve .ltlml files as HTML and enable clean URL routing.
#
# For production deployment, pre-compile .ltlml → .html using:
#   python scripts/build_docs.py --output /var/www/docs/
#
# This .htaccess handles the fallback case where .ltlml source
# files are deployed directly.
# ===============================================================

# -- MIME Types ------------------------------------------------
# Serve .ltlml and .ltlm files as HTML
AddType text/html .ltlml
AddType text/html .ltlm

# -- Charset ---------------------------------------------------
AddDefaultCharset UTF-8

# -- URL Rewriting ---------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the request is for a .html file that doesn't exist,
    # try the corresponding .ltlml file
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.ltlml -f
    RewriteRule ^(.*)$ $1.ltlml [L]

    # Rewrite .html requests to .ltlml if the .html doesn't
    # exist but the .ltlml does
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)\.html$ $1.ltlml [L]

    # Directory index: try index.ltlml before index.html
    DirectoryIndex index.ltlml index.html
</IfModule>

# -- Caching ---------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# -- Security --------------------------------------------------
# Prevent directory listing
Options -Indexes

# Deny access to source files that shouldn't be served
<FilesMatch "\.(py|pyc|toml|cfg|ini|sh|md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>
