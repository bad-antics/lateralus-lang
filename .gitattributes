# ===============================================================
# Lateralus Language — GitHub Linguist Configuration
# ===============================================================
# Lateralus has unique file extensions (.ltl, .ltasm, .ltlml).
# These are NOT Rust — Lateralus is its own language.
# linguist-language=Lateralus tells GitHub to show "Lateralus"
# in the repo language bar (colour assigned once added to
# github/linguist; shows as grey/unknown until then).
# ===============================================================

# -- Lateralus source files (the actual language) --------------
*.ltl     linguist-language=Lateralus linguist-detectable=true
*.ltasm   linguist-language=Lateralus linguist-detectable=true
*.ltlml   linguist-language=Lateralus linguist-detectable=true
*.ltlm    linguist-language=Lateralus linguist-detectable=true
*.ltlcfg  linguist-language=Lateralus linguist-detectable=true
*.ltlnb   linguist-language=Lateralus linguist-detectable=true

# -- Toolchain (Python implementation — not the language itself) --
# Vendored so Python doesn't dominate the language stats.
lateralus_lang/*.py linguist-vendored
lateralus_lang/**/*.py linguist-vendored
tests/*.py linguist-vendored
tests/**/*.py linguist-vendored
scripts/*.py linguist-vendored
docs/*.py linguist-vendored
lateralus-os/**/*.py linguist-vendored
setup.py linguist-vendored
conftest.py linguist-vendored

# -- VS Code extension (JavaScript implementation) --------------
vscode-lateralus/*.js linguist-vendored

# -- Binary / generated formats ---------------------------------
*.ltbc linguist-generated
*.ltlc linguist-generated
*.vsix linguist-generated
dist/** linguist-generated
