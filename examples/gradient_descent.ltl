import math / import strings / import crypto / import io

// ─── SECTION: HELPER FUNCTIONS ───────────────────────────────
let mean(list: list[float]) -> float {
    let sum = list |> map(fn(x) { x }) |> reduce((a, b) => a + b)
    return sum / len(list)
}

let variance(list: list[float]) -> float {
    let mean_val = mean(list)
    return list |> map(fn(x) { (x - mean_val) * (x - mean_val)}) |> reduce((a, b) => a + b) / len(list)
}

let covariance(list1: list[float], list2: list[float]) -> float {
    let list_product = list1 |> zip(list2) |> map(fn(x) { x[0] * x[1] })
    return list_product |> reduce((a, b) => a + b) / len(list1)
}

let gradient_descent(list: list[float], learning_rate: float, num_iterations: int) -> list[float] {
    let prev_gradients = [0.0]
    for _ in range(num_iterations) {
        let current_gradients = list |> map(fn(x) { -2 * covariance(prev_gradients, list) * x }) |> filter(fn(x) { x != 0 })
        prev_gradients := current_gradients
        // Update weights using the gradients and the learning rate
        // This is where we would update the weights using the gradients and the learning rate,
        // but since Lateralus doesn't have built-in support for matrix operations,
        // we'll just use the gradients as is.
        // For logistic regression, we need to apply the sigmoid function.
        if list[0] == 1 {
            return list
        } else {
            return list |> map(fn(x) { math.exp(-x) / (math.exp(-x) + 1)}) |> map(math.log)
        }
    }
    return list
}

