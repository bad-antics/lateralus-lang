{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lateralus Markup",
  "scopeName": "source.ltlm",
  "fileTypes": ["ltlm", "ltlml"],
  "patterns": [
    { "include": "#front-matter" },
    { "include": "#math-block" },
    { "include": "#ltlm-blocks-admonition" },
    { "include": "#ltlm-blocks-theorem" },
    { "include": "#fenced-code-lateralus" },
    { "include": "#fenced-code-lateralus-asm" },
    { "include": "#fenced-code-generic" },
    { "include": "#headings" },
    { "include": "#horizontal-rule" },
    { "include": "#blockquote" },
    { "include": "#unordered-list" },
    { "include": "#ordered-list" },
    { "include": "#table-separator" },
    { "include": "#table-row" },
    { "include": "#figure" },
    { "include": "#inline" }
  ],
  "repository": {

    "front-matter": {
      "name": "meta.front-matter.ltlm",
      "begin": "\\A---\\s*$",
      "end": "^---\\s*$",
      "beginCaptures": { "0": { "name": "punctuation.definition.front-matter.begin.ltlm" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.front-matter.end.ltlm" } },
      "patterns": [
        {
          "name": "meta.front-matter.entry.ltlm",
          "match": "^([A-Za-z_][A-Za-z0-9_-]*)\\s*(:)\\s*(.*?)\\s*$",
          "captures": {
            "1": { "name": "entity.name.tag.front-matter.key.ltlm" },
            "2": { "name": "punctuation.separator.key-value.ltlm" },
            "3": { "name": "string.unquoted.front-matter.value.ltlm" }
          }
        }
      ]
    },

    "math-block": {
      "name": "markup.math.block.ltlm",
      "begin": "^\\$\\$\\s*$",
      "end": "^\\$\\$\\s*$",
      "beginCaptures": { "0": { "name": "punctuation.definition.math.begin.ltlm" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.math.end.ltlm" } },
      "contentName": "markup.math.content.ltlm"
    },

    "ltlm-blocks-admonition": {
      "name": "meta.block.admonition.ltlm",
      "begin": "^(:::)\\s*(note|warning|tip|danger|info|success|output|example)(?:\\s+(.*))?$",
      "end": "^(:::)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.block.ltlm" },
        "2": { "name": "keyword.other.block-type.admonition.ltlm" },
        "3": { "name": "string.unquoted.block-title.ltlm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.block.ltlm" }
      },
      "patterns": [
        { "include": "#inline" }
      ]
    },

    "ltlm-blocks-theorem": {
      "name": "meta.block.theorem.ltlm",
      "begin": "^(:::)\\s*(theorem|lemma|corollary|definition|proposition|proof|remark|example|axiom|conjecture)(?:\\s+(.*))?$",
      "end": "^(:::)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.block.ltlm" },
        "2": { "name": "keyword.other.block-type.theorem.ltlm" },
        "3": { "name": "entity.name.type.theorem-title.ltlm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.block.ltlm" }
      },
      "patterns": [
        { "include": "#math-inline" },
        { "include": "#inline" }
      ]
    },

    "fenced-code-lateralus": {
      "name": "markup.fenced_code.block.ltlm",
      "begin": "^(`{3,})(lateralus|ltl)\\s*$",
      "end": "^(`{3,})\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.fenced-code.begin.ltlm" },
        "2": { "name": "entity.name.type.fenced-code.language.ltlm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.fenced-code.end.ltlm" }
      },
      "contentName": "meta.embedded.block.lateralus",
      "patterns": [
        { "include": "source.ltl" }
      ]
    },

    "fenced-code-lateralus-asm": {
      "name": "markup.fenced_code.block.ltlm",
      "begin": "^(`{3,})(lateralus-asm|ltasm)\\s*$",
      "end": "^(`{3,})\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.fenced-code.begin.ltlm" },
        "2": { "name": "entity.name.type.fenced-code.language.ltlm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.fenced-code.end.ltlm" }
      },
      "contentName": "meta.embedded.block.lateralus-asm",
      "patterns": [
        { "include": "source.ltasm" }
      ]
    },

    "fenced-code-generic": {
      "name": "markup.fenced_code.block.ltlm",
      "begin": "^(`{3,})(\\w[\\w+-]*)\\s*$",
      "end": "^(`{3,})\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.fenced-code.begin.ltlm" },
        "2": { "name": "entity.name.type.fenced-code.language.ltlm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.fenced-code.end.ltlm" }
      },
      "contentName": "markup.raw.block.ltlm"
    },

    "headings": {
      "patterns": [
        {
          "name": "markup.heading.1.ltlm",
          "match": "^(#{1})(?!#)\\s+(.+)$",
          "captures": {
            "1": { "name": "punctuation.definition.heading.ltlm" },
            "2": { "name": "entity.name.section.h1.ltlm" }
          }
        },
        {
          "name": "markup.heading.2.ltlm",
          "match": "^(#{2})(?!#)\\s+(.+)$",
          "captures": {
            "1": { "name": "punctuation.definition.heading.ltlm" },
            "2": { "name": "entity.name.section.h2.ltlm" }
          }
        },
        {
          "name": "markup.heading.3.ltlm",
          "match": "^(#{3})(?!#)\\s+(.+)$",
          "captures": {
            "1": { "name": "punctuation.definition.heading.ltlm" },
            "2": { "name": "entity.name.section.h3.ltlm" }
          }
        },
        {
          "name": "markup.heading.4.ltlm",
          "match": "^(#{4})(?!#)\\s+(.+)$",
          "captures": {
            "1": { "name": "punctuation.definition.heading.ltlm" },
            "2": { "name": "entity.name.section.h4.ltlm" }
          }
        },
        {
          "name": "markup.heading.5.ltlm",
          "match": "^(#{5})(?!#)\\s+(.+)$",
          "captures": {
            "1": { "name": "punctuation.definition.heading.ltlm" },
            "2": { "name": "entity.name.section.h5.ltlm" }
          }
        },
        {
          "name": "markup.heading.6.ltlm",
          "match": "^(#{6})\\s+(.+)$",
          "captures": {
            "1": { "name": "punctuation.definition.heading.ltlm" },
            "2": { "name": "entity.name.section.h6.ltlm" }
          }
        }
      ]
    },

    "horizontal-rule": {
      "name": "markup.thematic-break.ltlm",
      "match": "^(?:-{3,}|\\*{3,}|_{3,})\\s*$"
    },

    "blockquote": {
      "name": "markup.quote.ltlm",
      "begin": "^(>)\\s?",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.quote.ltlm" }
      },
      "contentName": "markup.quote.text.ltlm",
      "patterns": [
        { "include": "#inline" }
      ]
    },

    "unordered-list": {
      "name": "markup.list.unnumbered.ltlm",
      "match": "^(\\s*[-*+])\\s+(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.list.bullet.ltlm" },
        "2": { "name": "markup.list.item.ltlm" }
      }
    },

    "ordered-list": {
      "name": "markup.list.numbered.ltlm",
      "match": "^(\\s*\\d+\\.)\\s+(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.list.number.ltlm" },
        "2": { "name": "markup.list.item.ltlm" }
      }
    },

    "table-separator": {
      "name": "markup.table.separator.ltlm",
      "match": "^\\|(?:\\s*:?-+:?\\s*\\|)+\\s*$",
      "captures": {
        "0": { "name": "punctuation.definition.table.separator.ltlm" }
      }
    },

    "table-row": {
      "name": "markup.table.row.ltlm",
      "match": "^(\\|)(.+)(\\|)\\s*$",
      "captures": {
        "1": { "name": "punctuation.definition.table.pipe.ltlm" },
        "2": { "name": "markup.table.content.ltlm" },
        "3": { "name": "punctuation.definition.table.pipe.ltlm" }
      }
    },

    "figure": {
      "name": "meta.figure.ltlm",
      "match": "^(@fig)\\{([^}]+)\\}\\{([^}]*)\\}\\s*$",
      "captures": {
        "1": { "name": "keyword.other.figure.ltlm" },
        "2": { "name": "markup.underline.link.ltlm" },
        "3": { "name": "string.unquoted.figure-caption.ltlm" }
      }
    },

    "math-inline": {
      "name": "markup.math.inline.ltlm",
      "match": "(\\$)([^$\\n]+)(\\$)",
      "captures": {
        "1": { "name": "punctuation.definition.math.inline.begin.ltlm" },
        "2": { "name": "markup.math.content.ltlm" },
        "3": { "name": "punctuation.definition.math.inline.end.ltlm" }
      }
    },

    "inline": {
      "patterns": [
        { "include": "#math-inline" },
        {
          "name": "markup.bold.ltlm",
          "match": "(\\*\\*)([^*\\n]+?)(\\*\\*)",
          "captures": {
            "1": { "name": "punctuation.definition.bold.begin.ltlm" },
            "2": { "name": "markup.bold.text.ltlm" },
            "3": { "name": "punctuation.definition.bold.end.ltlm" }
          }
        },
        {
          "name": "markup.italic.ltlm",
          "match": "(\\*|_)([^*_\\n]+?)(\\*|_)",
          "captures": {
            "1": { "name": "punctuation.definition.italic.begin.ltlm" },
            "2": { "name": "markup.italic.text.ltlm" },
            "3": { "name": "punctuation.definition.italic.end.ltlm" }
          }
        },
        {
          "name": "markup.strikethrough.ltlm",
          "match": "(~~)([^~\\n]+)(~~)",
          "captures": {
            "1": { "name": "punctuation.definition.strikethrough.begin.ltlm" },
            "2": { "name": "markup.strikethrough.text.ltlm" },
            "3": { "name": "punctuation.definition.strikethrough.end.ltlm" }
          }
        },
        {
          "name": "markup.inline.raw.ltlm",
          "match": "(`+)([^`]+)(`+)",
          "captures": {
            "1": { "name": "punctuation.definition.raw.begin.ltlm" },
            "2": { "name": "markup.raw.inline.ltlm" },
            "3": { "name": "punctuation.definition.raw.end.ltlm" }
          }
        },
        {
          "comment": "Image: ![alt](src)",
          "name": "meta.image.ltlm",
          "match": "(!\\[)([^\\]]*)(\\])(\\()([^)]*)(\\))",
          "captures": {
            "1": { "name": "punctuation.definition.image.begin.ltlm" },
            "2": { "name": "string.other.image-alt.ltlm" },
            "3": { "name": "punctuation.definition.image.end.ltlm" },
            "4": { "name": "punctuation.definition.link.begin.ltlm" },
            "5": { "name": "markup.underline.link.ltlm" },
            "6": { "name": "punctuation.definition.link.end.ltlm" }
          }
        },
        {
          "comment": "Link: [text](href)",
          "name": "meta.link.ltlm",
          "match": "(\\[)([^\\]]*)(\\])(\\()([^)]*)(\\))",
          "captures": {
            "1": { "name": "punctuation.definition.link.begin.ltlm" },
            "2": { "name": "string.other.link-text.ltlm" },
            "3": { "name": "punctuation.definition.link.end.ltlm" },
            "4": { "name": "punctuation.definition.link.begin.ltlm" },
            "5": { "name": "markup.underline.link.ltlm" },
            "6": { "name": "punctuation.definition.link.end.ltlm" }
          }
        },
        {
          "comment": "Cross-reference: @ref{label}",
          "name": "meta.crossref.ltlm",
          "match": "(@ref)\\{([^}]+)\\}",
          "captures": {
            "1": { "name": "keyword.other.crossref.ltlm" },
            "2": { "name": "entity.name.label.crossref.ltlm" }
          }
        },
        {
          "comment": "Citation: @cite{key}",
          "name": "meta.citation.ltlm",
          "match": "(@cite)\\{([^}]+)\\}",
          "captures": {
            "1": { "name": "keyword.other.citation.ltlm" },
            "2": { "name": "entity.name.label.citation.ltlm" }
          }
        },
        {
          "comment": "Equation label: @eq{label}",
          "name": "meta.equation-label.ltlm",
          "match": "(@eq)\\{([^}]+)\\}",
          "captures": {
            "1": { "name": "keyword.other.equation-label.ltlm" },
            "2": { "name": "entity.name.label.equation.ltlm" }
          }
        }
      ]
    }
  }
}
