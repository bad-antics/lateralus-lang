<!-- INSTALL -->
<section id="install" style="text-align:center;">
  <div class="section-label">Get Started</div>
  <h2 class="section-title">Install LATERALUS</h2>
  <p class="section-sub" style="margin:0 auto 2rem;">
    Python 3.10+ required. Works on Linux, macOS, and Windows.
  </p>
  <div style="display:flex; flex-direction:column; align-items:center; gap:.75rem;">
    <div class="install-cmd">
      <span class="prompt">$</span>
      <span>git clone https://github.com/lateralus-lang/lateralus</span>
      <button class="copy-btn" onclick="copyCmd(this,'git clone https://github.com/lateralus-lang/lateralus')">copy</button>
    </div>
    <div class="install-cmd">
      <span class="prompt">$</span>
      <span>pip install -e lateralus/</span>
      <button class="copy-btn" onclick="copyCmd(this,'pip install -e lateralus/')">copy</button>
    </div>
    <div class="install-cmd">
      <span class="prompt">$</span>
      <span>lateralus run examples/v19_showcase.ltl</span>
      <button class="copy-btn" onclick="copyCmd(this,'lateralus run examples/v19_showcase.ltl')">copy</button>
    </div>
  </div>
  <p style="margin-top:2rem;color:var(--dim);font-size:.9rem;">
    Or create a new project: &nbsp;
    <code style="background:var(--card);padding:.2rem .5rem;border-radius:4px;font-family:var(--mono);">ltlpkg init my-project</code>
  </p>
</section>

