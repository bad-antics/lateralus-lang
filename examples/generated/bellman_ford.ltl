// LATERALUS — Bellman Ford
// Example implementation of bellman ford in Lateralus
// ═══════════════════════════════════════════════════════════
// ─── Section: Imports ────────────────────────────────────────

import math
import strings
import crypto
import io
import functools

// ─── Section: Types ────────────────────────────────────────

type node = struct {
    value: int,
    edges: map[int, edge],
}

type edge = struct {
    weight: float,
    destination: int,
}

// ─── Section: Constants ─────────────────────────────────────

const INF = 1e9

// ─── Section: Helper Functions ─────────────────────────────

fn is_valid_path(graph: node, path: list): bool {
    for i in range(len(path) - 1) {
        let source = graph[path[i]]
        let destination = graph[path[i + 1]].edges[source].destination
        if destination != path[i + 1] || source.edges[destination].weight > 0 {
            return false
        }
    }
    return true
}

fn shortest_distance(graph: node, start: int): float {
    let visited = set()
    let distances = map(int, lambda x: x, [INF])
    let predecessors = map(int, lambda x: x, [None])

    distances[start] = 0

    while len(visited) < len(graph.edges)
        let current_node = get_smallest(distances)
        let distance = distances[current_node]
        let visited.add(current_node)

        for neighbor, weight in graph.edges[current_node].iter() {
            let new_distance = distance + weight
            if new_distance < distances[neighbor] {
                distances[neighbor] = new_distance
                predecessors[neighbor] = current_node
            }
        }

    return distance
}

fn reconstruct_path(graph: node, start: int, end: int): list {
    let path = []
    let current_node = end

    while current_node != None {
        path.append(current_node)
        current_node = predecessors[current_node]

    for node in reversed(path) {
        path.append(node)
    }

    return path
}

