{h2 Chapter 6: Cryptography Recipes}

{h3 Recipe 6.1 — Secure Password Hashing}

{code lang="lateralus"
import "crypto"

-- Hash a password with PBKDF2 (use in user registration)
fn hash_password(password: str) -> str {
    let salt = crypto.random_bytes(32)  -- 256-bit salt
    let hash = crypto.pbkdf2(
        password: password,
        salt:     salt,
        iterations: 600_000,            -- NIST 2024 recommended
        key_len:  32,
        algorithm: "sha256"
    )
    -- Store as "salt:hash" (both hex-encoded)
    return crypto.to_hex(salt) + ":" + crypto.to_hex(hash)
}

-- Verify a password against a stored hash
fn verify_password(password: str, stored: str) -> bool {
    let [salt_hex, hash_hex] = split(stored, ":")
    let salt = crypto.from_hex(salt_hex)
    let expected = crypto.from_hex(hash_hex)
    let actual = crypto.pbkdf2(
        password: password,
        salt:     salt,
        iterations: 600_000,
        key_len:  32,
        algorithm: "sha256"
    )
    return crypto.constant_time_compare(actual, expected)
}
}

{h3 Recipe 6.2 — Encrypt and Decrypt a File}

{code lang="lateralus"
import "crypto"
import "io"

fn encrypt_file(input_path: str, output_path: str, password: str) -> None {
    let plaintext = io.read_bytes(input_path)
    let salt = crypto.random_bytes(16)
    let key  = crypto.pbkdf2(password, salt, iterations: 100_000, key_len: 32)
    let iv, ciphertext, tag = crypto.aes_gcm_encrypt(plaintext, key)
    -- Format: [salt(16)] [iv(12)] [tag(16)] [ciphertext]
    io.write_bytes(output_path, salt + iv + tag + ciphertext)
}

fn decrypt_file(input_path: str, output_path: str, password: str) -> None {
    let data       = io.read_bytes(input_path)
    let salt       = data[0:16]
    let iv         = data[16:28]
    let tag        = data[28:44]
    let ciphertext = data[44:]
    let key        = crypto.pbkdf2(password, salt, iterations: 100_000, key_len: 32)
    let plaintext  = crypto.aes_gcm_decrypt(ciphertext, key, iv, tag)
    io.write_bytes(output_path, plaintext)
}
}

