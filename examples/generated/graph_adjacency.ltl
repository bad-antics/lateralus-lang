// Section: Main Function
async fn main() {
    // create a sample graph
    let graph = struct {
        0: [1 2],
        1: [],
        2: [0]
    }.map()

    // print initial graph
    println("Initial Graph:")
    io.print(graph)

    // perform BFS traversal
    let order = bfs(graph)
    println("\nBFS Traversal Order:")
    io.println(order)

    // perform DFS traversal
    let depthFirstSearch = dfs(graph)
    println("\nDepth-First Search Order:")
    io.println(depthFirstSearch)

