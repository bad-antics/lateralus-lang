{
  "New Notebook": {
    "prefix": "notebook",
    "body": [
      "{",
      "  \"lateralus_version\": \"1.5\",",
      "  \"metadata\": {",
      "    \"title\": \"${1:Untitled Notebook}\",",
      "    \"author\": \"${2:author}\",",
      "    \"kernel\": \"lateralus\"",
      "  },",
      "  \"cells\": [",
      "    {",
      "      \"cell_type\": \"${3|code,markdown,math|}\",",
      "      \"source\": [\"${4:}\"],",
      "      \"outputs\": [],",
      "      \"execution_count\": null",
      "    }",
      "  ]",
      "}"
    ],
    "description": "Create a new Lateralus notebook structure"
  },
  "Code Cell": {
    "prefix": "cell-code",
    "body": [
      "{",
      "  \"cell_type\": \"code\",",
      "  \"source\": [\"${1:}\"],",
      "  \"outputs\": [],",
      "  \"execution_count\": null",
      "}"
    ],
    "description": "Add a code cell"
  },
  "Markdown Cell": {
    "prefix": "cell-md",
    "body": [
      "{",
      "  \"cell_type\": \"markdown\",",
      "  \"source\": [\"${1:# Heading}\"],",
      "  \"outputs\": []",
      "}"
    ],
    "description": "Add a markdown cell"
  },
  "Math Cell": {
    "prefix": "cell-math",
    "body": [
      "{",
      "  \"cell_type\": \"math\",",
      "  \"source\": [\"${1:$$\\\\int_0^1 f(x) dx$$}\"],",
      "  \"outputs\": []",
      "}"
    ],
    "description": "Add a math cell"
  }
}
